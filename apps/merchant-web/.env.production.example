NEXT_PUBLIC_API_URL=https://api.jebdekho.com/api/v1
NEXT_PUBLIC_API_ORIGIN=https://api.jebdekho.com
NEXT_PUBLIC_APP_URL=https://merchant.jebdekho.com

# Google Maps — Maps JavaScript API + Places API for exact pickup address.
# Restrict this browser key by HTTP referrer, e.g. https://merchant.jebdekho.com/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=

# Auth UI — mobile OTP disabled until MSG91/DLT approval
NEXT_PUBLIC_AUTH_PHONE_OTP_ENABLED=false
