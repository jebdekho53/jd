  signature    String?
  status       ProviderWebhookStatus @default(RECEIVED)
  errorMessage String?               @map("error_message") @db.Text
  processedAt  DateTime?             @map("processed_at")
  createdAt    DateTime              @default(now()) @map("created_at")

  provider DeliveryProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@unique([providerType, eventId])
  @@index([providerId, status, createdAt(sort: Desc)])
  @@map("provider_webhooks")
}

