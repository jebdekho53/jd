model Campaign {
  id                String         @id @default(cuid())
  name              String
  description       String?
  scope             CampaignScope
  storeId           String?        @map("store_id")
  status            CampaignStatus @default(DRAFT)
  stackMode         OfferStackMode @default(BEST_OFFER) @map("stack_mode")
  startsAt          DateTime       @map("starts_at")
  endsAt            DateTime       @map("ends_at")
  budgetCap         Decimal?       @map("budget_cap") @db.Decimal(12, 2)
  spentAmount       Decimal        @default(0) @map("spent_amount") @db.Decimal(12, 2)
  impressionCount   Int            @default(0) @map("impression_count")
  clickCount        Int            @default(0) @map("click_count")
  orderCount        Int            @default(0) @map("order_count")
  gmvGenerated      Decimal        @default(0) @map("gmv_generated") @db.Decimal(14, 2)
  createdById       String?        @map("created_by_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  store     Store?              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  offers    Offer[]
  audiences CampaignAudience[]
  events    CampaignEvent[]
  commissionRules CommissionRule[]

  @@index([scope, status])
  @@index([storeId, status])
  @@index([startsAt, endsAt])
  @@map("campaigns")
}

model Offer {
  id                String           @id @default(cuid())
  campaignId        String           @map("campaign_id")
  storeId           String?          @map("store_id")
  name              String
  description       String?
  kind              OfferKind
  target            PromotionTarget  @default(STORE_WIDE)
  categoryId        String?          @map("category_id")
  productId         String?          @map("product_id")
  variantId         String?          @map("variant_id")
  discountValue     Decimal          @map("discount_value") @db.Decimal(10, 2)
  cashbackAmount    Decimal?         @map("cashback_amount") @db.Decimal(10, 2)
  rewardPointsBonus Int?             @map("reward_points_bonus")
  buyQuantity       Int?             @map("buy_quantity")
  getQuantity       Int?             @map("get_quantity")
  minOrderAmount    Decimal          @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscount       Decimal?         @map("max_discount") @db.Decimal(10, 2)
  usageLimit        Int?             @map("usage_limit")
  usedCount         Int              @default(0) @map("used_count")
  perUserLimit      Int              @default(1) @map("per_user_limit")
  flashQtyLimit     Int?             @map("flash_qty_limit")
  flashQtySold      Int              @default(0) @map("flash_qty_sold")
  startsAt          DateTime         @map("starts_at")
  expiresAt         DateTime         @map("expires_at")
  isActive          Boolean          @default(true) @map("is_active")
  pausedAt          DateTime?        @map("paused_at")
  priority          Int              @default(0)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  campaign Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  store    Store?     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product  Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  rules    OfferRule[]
  usages   OfferUsage[]
  carts    Cart[]
  events   CampaignEvent[]

  @@index([campaignId, isActive])
  @@index([storeId, isActive])
  @@index([kind])
  @@index([expiresAt])
  @@map("offers")
}

model OfferRule {
  id       String        @id @default(cuid())
  offerId  String        @map("offer_id")
  ruleType OfferRuleType @map("rule_type")
  config   Json

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("offer_rules")
}

model OfferUsage {
  id                  String   @id @default(cuid())
  offerId             String   @map("offer_id")
  orderId             String   @unique @map("order_id")
  buyerProfileId      String   @map("buyer_profile_id")
  discountApplied     Decimal  @default(0) @map("discount_applied") @db.Decimal(10, 2)
  cashbackApplied     Decimal  @default(0) @map("cashback_applied") @db.Decimal(10, 2)
  rewardPointsGranted Int      @default(0) @map("reward_points_granted")
  gmvImpact           Decimal  @default(0) @map("gmv_impact") @db.Decimal(12, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Restrict)

  @@index([offerId])
  @@index([buyerProfileId])
  @@map("offer_usages")
}

model CampaignAudience {
  id           String       @id @default(cuid())
  campaignId   String       @map("campaign_id")
  audienceType AudienceType @map("audience_type")
  config       Json

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_audiences")
}

model CampaignEvent {
  id             String            @id @default(cuid())
  campaignId     String            @map("campaign_id")
  offerId        String?           @map("offer_id")
  eventType      CampaignEventType @map("event_type")
  buyerProfileId String?           @map("buyer_profile_id")
  storeId        String?           @map("store_id")
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([campaignId, eventType, createdAt(sort: Desc)])
  @@index([offerId])
  @@map("campaign_events")
}

