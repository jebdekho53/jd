// Jebdekho — Production PostgreSQL Schema
// Run: npx prisma migrate dev (after Phase 1 approval)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

