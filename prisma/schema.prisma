  stateCode String   @unique @map("state_code")
  stateName String   @map("state_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tax_jurisdictions")
}

model TaxRate {
  id         String   @id @default(cuid())
  slab       GstSlab
  cgstRate   Decimal  @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate   Decimal  @map("sgst_rate") @db.Decimal(5, 2)
  igstRate   Decimal  @map("igst_rate") @db.Decimal(5, 2)
  totalRate  Decimal  @map("total_rate") @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([slab])
  @@map("tax_rates")
}

model HSNCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String
  defaultGstSlab  GstSlab  @map("default_gst_slab")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("hsn_codes")
}

model GstInvoiceSequence {
  id           String @id @default(cuid())
  periodKey    String @unique @map("period_key")
  lastSequence Int    @default(0) @map("last_sequence")

  @@map("gst_invoice_sequences")
}

model GSTInvoice {
  id              String           @id @default(cuid())
  invoiceNumber   String           @unique @map("invoice_number")
  orderId         String           @unique @map("order_id")
  storeId         String           @map("store_id")
  merchantProfileId String         @map("merchant_profile_id")
  buyerProfileId  String           @map("buyer_profile_id")
  status          GstInvoiceStatus @default(FINALIZED)
  supplyType      GstSupplyType    @map("supply_type")
  supplierGstin   String?          @map("supplier_gstin")
  buyerGstin      String?          @map("buyer_gstin")
  supplierState   String           @map("supplier_state")
  buyerState      String?          @map("buyer_state")
  placeOfSupply   String           @map("place_of_supply")
  subtotal        Decimal          @db.Decimal(12, 2)
  discountAmount  Decimal          @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxableAmount   Decimal          @map("taxable_amount") @db.Decimal(12, 2)
  cgstAmount      Decimal          @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount      Decimal          @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount      Decimal          @default(0) @map("igst_amount") @db.Decimal(12, 2)
  totalTax        Decimal          @map("total_tax") @db.Decimal(12, 2)
  deliveryFee     Decimal          @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  grandTotal      Decimal          @map("grand_total") @db.Decimal(12, 2)
  pdfStorageKey   String?          @map("pdf_storage_key")
  isImmutable     Boolean          @default(true) @map("is_immutable")
  emailedAt       DateTime?        @map("emailed_at")
  invoiceDate     DateTime         @default(now()) @map("invoice_date")
  createdAt       DateTime         @default(now()) @map("created_at")

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  lines           GSTInvoiceLine[]
  creditNotes     CreditNote[]

  @@index([merchantProfileId, invoiceDate(sort: Desc)])
  @@index([invoiceDate(sort: Desc)])
  @@map("gst_invoices")
}

model GSTInvoiceLine {
  id            String   @id @default(cuid())
  invoiceId     String   @map("invoice_id")
  orderItemId   String?  @map("order_item_id")
  productName   String   @map("product_name")
  hsnCode       String   @map("hsn_code")
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxableAmount Decimal  @map("taxable_amount") @db.Decimal(12, 2)
  gstSlab       GstSlab  @map("gst_slab")
  cgstRate      Decimal  @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate      Decimal  @map("sgst_rate") @db.Decimal(5, 2)
  igstRate      Decimal  @map("igst_rate") @db.Decimal(5, 2)
  cgstAmount    Decimal  @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal  @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal  @default(0) @map("igst_amount") @db.Decimal(10, 2)
  lineTotal     Decimal  @map("line_total") @db.Decimal(12, 2)

  invoice GSTInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("gst_invoice_lines")
}

model CreditNote {
  id              String           @id @default(cuid())
  creditNoteNumber String          @unique @map("credit_note_number")
  invoiceId       String           @map("invoice_id")
  orderId         String           @map("order_id")
  status          CreditNoteStatus @default(ISSUED)
  reason          String           @db.Text
  taxableAmount   Decimal          @map("taxable_amount") @db.Decimal(12, 2)
  cgstAmount      Decimal          @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount      Decimal          @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount      Decimal          @default(0) @map("igst_amount") @db.Decimal(12, 2)
  totalTax        Decimal          @map("total_tax") @db.Decimal(12, 2)
  grandTotal      Decimal          @map("grand_total") @db.Decimal(12, 2)
  isPartial       Boolean          @default(false) @map("is_partial")
  pdfStorageKey   String?          @map("pdf_storage_key")
  emailedAt       DateTime?        @map("emailed_at")
  issuedAt        DateTime         @default(now()) @map("issued_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  invoice GSTInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  order   Order      @relation(fields: [orderId], references: [id], onDelete: Restrict)
  lines   CreditNoteLine[]

  @@index([orderId])
  @@index([issuedAt(sort: Desc)])
  @@map("credit_notes")
}

model CreditNoteLine {
  id            String  @id @default(cuid())
  creditNoteId  String  @map("credit_note_id")
  productName   String  @map("product_name")
  hsnCode       String  @map("hsn_code")
  quantity      Int
  taxableAmount Decimal @map("taxable_amount") @db.Decimal(12, 2)
  cgstAmount    Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)
  lineTotal     Decimal @map("line_total") @db.Decimal(12, 2)

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
  @@map("credit_note_lines")
}

model DebitNote {
  id               String          @id @default(cuid())
  debitNoteNumber  String          @unique @map("debit_note_number")
  invoiceId        String?         @map("invoice_id")
  orderId          String?         @map("order_id")
  merchantProfileId String         @map("merchant_profile_id")
  status           DebitNoteStatus @default(ISSUED)
  reason           String          @db.Text
  taxableAmount    Decimal         @map("taxable_amount") @db.Decimal(12, 2)
  totalTax         Decimal         @map("total_tax") @db.Decimal(12, 2)
  grandTotal       Decimal         @map("grand_total") @db.Decimal(12, 2)
  issuedAt         DateTime        @default(now()) @map("issued_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)

  @@index([merchantProfileId])
  @@map("debit_notes")
}

model TdsRecord {
  id                String   @id @default(cuid())
  merchantProfileId String   @map("merchant_profile_id")
  periodMonth       String   @map("period_month")
  taxableAmount     Decimal  @map("taxable_amount") @db.Decimal(14, 2)
  tdsRate           Decimal  @map("tds_rate") @db.Decimal(5, 2)
  tdsAmount         Decimal  @map("tds_amount") @db.Decimal(12, 2)
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)

  @@index([periodMonth])
  @@index([merchantProfileId, periodMonth])
  @@map("tds_records")
}

model TcsRecord {
  id           String   @id @default(cuid())
  periodMonth  String   @map("period_month")
  gmvAmount    Decimal  @map("gmv_amount") @db.Decimal(14, 2)
  tcsRate      Decimal  @map("tcs_rate") @db.Decimal(5, 2)
  tcsAmount    Decimal  @map("tcs_amount") @db.Decimal(12, 2)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([periodMonth])
  @@map("tcs_records")
}

// =============================================================================
// ENTERPRISE RISK, FRAUD & TRUST & SAFETY (P5.3)
// =============================================================================

enum RiskProfileStatus {
  CLEAR
  WATCHLIST
  REVIEW
  BLOCKED
}

enum FraudCaseStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum FraudCaseCategory {
  REFERRAL_ABUSE
  WALLET_ABUSE
  COUPON_ABUSE
  COD_ABUSE
  RIDER_FRAUD
  MERCHANT_FRAUD
  ACCOUNT_TAKEOVER
  BOT_TRAFFIC
  LOCATION_SPOOFING
  ORDER_FRAUD
  OTHER
}

enum FraudDecisionAction {
  ALLOW
  WARN
  SOFT_BLOCK
  HARD_BLOCK
  WALLET_FREEZE
  REFERRAL_FREEZE
  COUPON_FREEZE
  COD_DISABLE
  MERCHANT_SUSPEND
  RIDER_SUSPEND
  RESTRICT
  BLACKLIST
}

enum AccountRestrictionType {
  SOFT_BLOCK
  HARD_BLOCK
  WALLET_FREEZE
  REFERRAL_FREEZE
  COUPON_FREEZE
  COD_DISABLE
  MERCHANT_SUSPEND
  RIDER_SUSPEND
}

enum TrustAlertType {
  FRAUD_SPIKE
  REFERRAL_ABUSE
  WALLET_ABUSE
  COD_ABUSE
  RIDER_ANOMALY
  MERCHANT_ANOMALY
  ACCOUNT_TAKEOVER
  BOT_TRAFFIC
}

model RiskProfile {
  id            String            @id @default(cuid())
  userId        String            @unique @map("user_id")
  status        RiskProfileStatus @default(CLEAR)
  riskScore     Int               @default(0) @map("risk_score")
  trustScore    Int               @default(100) @map("trust_score")
  fraudScore    Int               @default(0) @map("fraud_score")
  codEnabled    Boolean           @default(true) @map("cod_enabled")
  walletFrozen  Boolean           @default(false) @map("wallet_frozen")
  referralFrozen Boolean          @default(false) @map("referral_frozen")
  couponFrozen  Boolean           @default(false) @map("coupon_frozen")
  lastEvaluatedAt DateTime?       @map("last_evaluated_at")
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([riskScore(sort: Desc)])
  @@map("risk_profiles")
}

model RiskEvent {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  eventType       String   @map("event_type")
  severity        String
  idempotencyKey  String   @unique @map("idempotency_key")
  subjectType     String?  @map("subject_type")
  subjectId       String?  @map("subject_id")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("risk_events")
}

model FraudCase {
  id           String            @id @default(cuid())
  caseNumber   String            @unique @map("case_number")
  userId       String?           @map("user_id")
  category     FraudCaseCategory
  status       FraudCaseStatus   @default(OPEN)
  severity     String
  title        String
  description  String            @db.Text
  subjectType  String?           @map("subject_type")
  subjectId    String?           @map("subject_id")
  idempotencyKey String?         @unique @map("idempotency_key")
  resolvedAt   DateTime?         @map("resolved_at")
  resolvedBy   String?           @map("resolved_by")
  resolution   String?           @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  decisions FraudDecision[]

  @@index([status, createdAt(sort: Desc)])
  @@index([category, status])
  @@index([userId])
  @@map("fraud_cases")
}

model FraudRule {
  id          String   @id @default(cuid())
  ruleCode    String   @unique @map("rule_code")
  name        String
  category    FraudCaseCategory
  description String?  @db.Text
  isEnabled   Boolean  @default(true) @map("is_enabled")
  weight      Int      @default(10)
  config      Json?
  action      FraudDecisionAction @default(WARN)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  decisions FraudDecision[]

  @@map("fraud_rules")
}

model FraudDecision {
  id             String              @id @default(cuid())
  fraudCaseId    String?             @map("fraud_case_id")
  fraudRuleId    String?             @map("fraud_rule_id")
  userId         String?             @map("user_id")
  decision       FraudDecisionAction
  actionTaken    Boolean             @default(false) @map("action_taken")
  idempotencyKey String              @unique @map("idempotency_key")
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")

  fraudCase FraudCase? @relation(fields: [fraudCaseId], references: [id], onDelete: SetNull)
  fraudRule FraudRule? @relation(fields: [fraudRuleId], references: [id], onDelete: SetNull)

  @@index([fraudCaseId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("fraud_decisions")
}

model DeviceFingerprint {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  deviceId    String   @map("device_id")
  fingerprint String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  os          String?
  city        String?
  state       String?
  accountCount Int     @default(1) @map("account_count")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessions LoginSession[]

  @@unique([deviceId, fingerprint])
  @@index([fingerprint])
  @@index([ipAddress])
  @@index([userId])
  @@map("device_fingerprints")
}

model LoginSession {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  sessionToken        String   @unique @map("session_token")
  deviceFingerprintId String?  @map("device_fingerprint_id")
  ipAddress           String?  @map("ip_address")
  userAgent           String?  @map("user_agent") @db.Text
  isNewDevice         Boolean  @default(false) @map("is_new_device")
  verifiedAt          DateTime? @map("verified_at")
  lastActiveAt        DateTime @default(now()) @map("last_active_at")
  revokedAt           DateTime? @map("revoked_at")
  createdAt           DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceFingerprint DeviceFingerprint? @relation(fields: [deviceFingerprintId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("login_sessions")
}

model GeoVerification {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  orderId   String?  @map("order_id")
  riderProfileId String? @map("rider_profile_id")
  latitude  Float
  longitude Float
  accuracy  Float?
  passed    Boolean  @default(true)
  flags     Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([orderId])
  @@map("geo_verifications")
}

model AccountRestriction {
  id              String                 @id @default(cuid())
  userId          String                 @map("user_id")
  restrictionType AccountRestrictionType @map("restriction_type")
  reason          String                 @db.Text
  active          Boolean                @default(true)
  appliedBy       String?                @map("applied_by")
  expiresAt       DateTime?              @map("expires_at")
  liftedAt        DateTime?              @map("lifted_at")
  liftedBy        String?                @map("lifted_by")
  createdAt       DateTime               @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([restrictionType, active])
  @@map("account_restrictions")
}

model TrustAlert {
  id        String           @id @default(cuid())
  alertType TrustAlertType   @map("alert_type")
  severity  String
  title     String
  message   String           @db.Text
  status    String           @default("OPEN")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  resolvedAt DateTime?       @map("resolved_at")

  @@index([status, createdAt(sort: Desc)])
  @@index([alertType, createdAt(sort: Desc)])
  @@map("trust_alerts")
}

// =============================================================================
// CUSTOMER SUPPORT, CRM & RESOLUTION CENTER (P5.4)
// =============================================================================

enum SupportChannel {
  CHAT
  EMAIL
  PHONE
  WHATSAPP
  IN_APP
}

enum SupportTicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  WAITING_CUSTOMER
  ESCALATED
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportActorType {
  BUYER
  MERCHANT
  RIDER
  ADMIN
  SYSTEM
}

enum SupportTeam {
  CUSTOMER_SUPPORT
  FINANCE
  MERCHANT_OPS
  RIDER_OPS
  COMPLIANCE
}

enum SupportMessageVisibility {
  PUBLIC
  INTERNAL
}

enum HelpArticleKind {
  FAQ
  GUIDE
  POLICY
}

model SupportCategory {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  audience    SupportActorType
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")

  tickets SupportTicket[]

  @@map("support_categories")
}

model SupportSla {
  id                String          @id @default(cuid())
  priority          SupportPriority @unique
  responseMinutes   Int             @map("response_minutes")
  resolutionMinutes Int             @map("resolution_minutes")
  escalationMinutes Int             @map("escalation_minutes")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@map("support_slas")
}

model SupportAgent {
  id        String       @id @default(cuid())
  userId    String       @unique @map("user_id")
  team      SupportTeam
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments SupportAssignment[]

  @@index([team, isActive])
  @@map("support_agents")
}

model SupportTicketSequence {
  id           String @id @default(cuid())
  periodKey    String @unique @map("period_key")
  lastSequence Int    @default(0) @map("last_sequence")

  @@map("support_ticket_sequences")
}

model SupportTicket {
  id                  String              @id @default(cuid())
  ticketNumber        String              @unique @map("ticket_number")
  requesterUserId     String              @map("requester_user_id")
  actorType           SupportActorType    @map("actor_type")
  channel             SupportChannel      @default(IN_APP)
  categoryId          String              @map("category_id")
  status              SupportTicketStatus @default(OPEN)
  priority            SupportPriority     @default(MEDIUM)
  subject             String
  description         String              @db.Text
  orderId             String?             @map("order_id")
  paymentId           String?             @map("payment_id")
  walletTransactionId String?             @map("wallet_transaction_id")
  gstInvoiceId        String?             @map("gst_invoice_id")
  isRefundDispute     Boolean             @default(false) @map("is_refund_dispute")
  assignedTeam        SupportTeam?        @map("assigned_team")
  firstResponseAt     DateTime?           @map("first_response_at")
  slaResponseDue      DateTime?           @map("sla_response_due")
  slaResolutionDue    DateTime?           @map("sla_resolution_due")
  resolvedAt          DateTime?           @map("resolved_at")
  closedAt            DateTime?           @map("closed_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  requester   User              @relation("TicketRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  category    SupportCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  messages    SupportMessage[]
  attachments SupportAttachment[]
  assignments SupportAssignment[]
  resolution  SupportResolution?
  escalations SupportEscalation[]
  feedback    SupportFeedback?
  tags        SupportTicketTag[]

  @@index([status, priority, createdAt(sort: Desc)])
  @@index([requesterUserId, createdAt(sort: Desc)])
  @@index([assignedTeam, status])
  @@index([isRefundDispute, status])
  @@map("support_tickets")
}

model SupportMessage {
  id         String                   @id @default(cuid())
  ticketId   String                   @map("ticket_id")
  authorId   String                   @map("author_id")
  body       String                   @db.Text
  visibility SupportMessageVisibility @default(PUBLIC)
  createdAt  DateTime                 @default(now()) @map("created_at")

  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments SupportAttachment[]

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model SupportAttachment {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  messageId String?  @map("message_id")
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  storageKey String  @map("storage_key")
  sizeBytes Int?     @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  ticket  SupportTicket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message SupportMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("support_attachments")
}

model SupportAssignment {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  agentId    String   @map("agent_id")
  assignedBy String?  @map("assigned_by")
  note       String?
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent  SupportAgent  @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([ticketId, isActive])
  @@index([agentId, isActive])
  @@map("support_assignments")
}

model SupportResolution {
  id          String   @id @default(cuid())
  ticketId    String   @unique @map("ticket_id")
  resolvedBy  String   @map("resolved_by")
  summary     String   @db.Text
  refundApproved Boolean? @map("refund_approved")
