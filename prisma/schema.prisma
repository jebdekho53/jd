enum DeliveryProviderType {
  SHADOWFAX
  PORTER
  DELHIVERY
  BORZO
  OWN_FLEET
}

enum ShipmentProviderStatus {
  PENDING
  ASSIGNED
  PICKUP_STARTED
  PICKED_UP
  IN_TRANSIT
  NEARBY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum ProviderWebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

model DeliveryProvider {
  id        String               @id @default(cuid())
