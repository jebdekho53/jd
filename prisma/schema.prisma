  @@map("delivery_providers")
}

model ProviderShipment {
  id                 String                 @id @default(cuid())
  orderId            String                 @unique @map("order_id")
  deliveryId         String?                @unique @map("delivery_id")
  providerId         String                 @map("provider_id")
  providerType       DeliveryProviderType   @map("provider_type")
  externalShipmentId String?                @map("external_shipment_id")
  trackingNumber     String?                @map("tracking_number")
  normalizedStatus   ShipmentProviderStatus @default(PENDING) @map("normalized_status")
  providerStatus     String?                @map("provider_status")
  estimatedEtaMins   Int?                   @map("estimated_eta_mins")
  estimatedArrivalAt DateTime?              @map("estimated_arrival_at")
  deliveryCost       Decimal?               @map("delivery_cost") @db.Decimal(10, 2)
  driverName         String?                @map("driver_name")
  driverPhone        String?                @map("driver_phone")
  vehicleType        String?                @map("vehicle_type")
  labelUrl           String?                @map("label_url")
  podUrl             String?                @map("pod_url")
  rawResponse        Json?                  @map("raw_response")
  retryCount         Int                    @default(0) @map("retry_count")
  lastError          String?                @map("last_error") @db.Text
  cancelledAt        DateTime?              @map("cancelled_at")
  deliveredAt        DateTime?              @map("delivered_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  delivery Delivery?        @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  provider DeliveryProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
