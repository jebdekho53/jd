  sortOrder  Int    @default(0) @map("sort_order")

  combo    RestaurantCombo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem RestaurantMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([comboId, menuItemId])
  @@map("restaurant_combo_items")
}

model FoodCart {
  id             String   @id @default(cuid())
  buyerProfileId String   @map("buyer_profile_id")
  storeId        String   @map("store_id")
  appliedCouponId String? @map("applied_coupon_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  appliedCoupon Coupon?     @relation(fields: [appliedCouponId], references: [id], onDelete: SetNull)
  items        FoodCartItem[]

  @@unique([buyerProfileId, storeId])
  @@index([buyerProfileId])
  @@map("food_carts")
}

model FoodCartItem {
  id                  String   @id @default(cuid())
  foodCartId          String   @map("food_cart_id")
  menuItemId          String   @map("menu_item_id")
  variantId           String?  @map("variant_id")
  comboId             String?  @map("combo_id")
  quantity            Int      @default(1)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(10, 2)
  specialInstructions String?  @map("special_instructions") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  foodCart FoodCart                   @relation(fields: [foodCartId], references: [id], onDelete: Cascade)
  menuItem RestaurantMenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variant  RestaurantMenuItemVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  addons   FoodCartItemAddon[]

  @@index([foodCartId])
  @@map("food_cart_items")
}

model FoodCartItemAddon {
  id           String  @id @default(cuid())
  cartItemId   String  @map("cart_item_id")
  addonId      String  @map("addon_id")
  addonGroupId String  @map("addon_group_id")
  price        Decimal @db.Decimal(10, 2)

  cartItem FoodCartItem    @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  addon    RestaurantAddon @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@index([cartItemId])
  @@map("food_cart_item_addons")
}

model FoodCheckout {
  id              String        @id @default(cuid())
  buyerProfileId  String        @map("buyer_profile_id")
  storeId         String        @map("store_id")
  status          String        @default("PENDING")
  subtotal        Decimal       @db.Decimal(10, 2)
  packagingFee    Decimal       @default(0) @map("packaging_fee") @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  tipAmount       Decimal       @default(0) @map("tip_amount") @db.Decimal(10, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress Json          @map("delivery_address")
  deliveryLat     Float         @map("delivery_lat")
  deliveryLng     Float         @map("delivery_lng")
  scheduledDeliveryAt DateTime? @map("scheduled_delivery_at")
  specialInstructions String?   @map("special_instructions") @db.Text
  restaurantNote  String?       @map("restaurant_note") @db.Text
  paymentMethod   PaymentMethod @map("payment_method")
  couponId        String?       @map("coupon_id")
  orderId         String?       @unique @map("order_id")
  idempotencyKey  String?       @unique @map("idempotency_key")
  razorpayOrderId String?       @unique @map("razorpay_order_id")
  cartSnapshot    Json?         @map("cart_snapshot")
  expiresAt       DateTime      @map("expires_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)

  @@index([buyerProfileId, status])
  @@map("food_checkouts")
}

model MenuOcrJob {
  id            String        @id @default(cuid())
  storeId       String        @map("store_id")
  imageUrl      String        @map("image_url") @db.Text
  status        MenuOcrStatus @default(UPLOADED)
  extractedJson Json?         @map("extracted_json")
  draftMenuJson Json?         @map("draft_menu_json")
  errorMessage  String?       @map("error_message") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@map("menu_ocr_jobs")
}

model RestaurantMenuSearchIndex {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  menuItemId  String   @unique @map("menu_item_id")
  name        String
  description String?  @db.Text
  cuisineName String?  @map("cuisine_name")
  categoryName String? @map("category_name")
  dietType    DietType @map("diet_type")
  searchVector Unsupported("tsvector")? @map("search_vector")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([storeId])
  @@map("restaurant_menu_search_index")
}

// =============================================================================
// MERCHANT-CONTROLLED RETURNS, REFUNDS & REPLACEMENTS
// =============================================================================

enum ClaimApprovalMode {
  AUTO
  MANUAL
}

enum ClaimProofRequirement {
  NONE
  PHOTO
  VIDEO
  PHOTO_AND_VIDEO
}

enum ClaimRefundMethod {
  ORIGINAL_PAYMENT
  WALLET
  BOTH
}

enum PreparedFoodPolicy {
  NO_RETURN
  REPLACEMENT_ONLY
  REFUND_ONLY
  MERCHANT_DECIDES
}

enum ReturnClaimReason {
  WRONG_ITEM
  DAMAGED
  MISSING_ITEM
  QUALITY_ISSUE
  EXPIRED_PRODUCT
  PACKAGING_DAMAGED
  NOT_AS_DESCRIBED
  CUSTOMER_CHANGED_MIND
  OTHER
}

enum OrderClaimType {
  RETURN
  REFUND
  REPLACEMENT
}

enum OrderClaimStatus {
  PENDING
  EVIDENCE_REQUESTED
  APPROVED
  REJECTED
  REPLACEMENT_APPROVED
  REPLACEMENT_SHIPPED
  REFUND_PROCESSING
  REFUND_PROCESSED
  CLOSED
}

enum ClaimActorType {
  BUYER
  MERCHANT
  ADMIN
  SYSTEM
}

model OrderClaim {
  id                 String            @id @default(cuid())
  claimNumber        String            @unique @map("claim_number")
  orderId            String            @map("order_id")
  buyerProfileId     String            @map("buyer_profile_id")
  storeId            String            @map("store_id")
  claimType          OrderClaimType    @map("claim_type")
  status             OrderClaimStatus  @default(PENDING)
  reason             ReturnClaimReason
  reasonNote         String?           @map("reason_note") @db.Text
  requestedAmount    Decimal           @default(0) @map("requested_amount") @db.Decimal(10, 2)
  approvedAmount     Decimal?          @map("approved_amount") @db.Decimal(10, 2)
  restockingFee      Decimal           @default(0) @map("restocking_fee") @db.Decimal(10, 2)
  idempotencyKey     String?           @map("idempotency_key")
  merchantNote       String?           @map("merchant_note") @db.Text
  adminNote          String?           @map("admin_note") @db.Text
  replacementOrderId String?           @map("replacement_order_id")
  returnPickupEnabled Boolean          @default(false) @map("return_pickup_enabled")
  returnShipmentId   String?           @map("return_shipment_id")
  resolvedAt         DateTime?         @map("resolved_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  order            Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  buyerProfile     BuyerProfile       @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  store            Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items            OrderClaimItem[]
  evidence         ClaimEvidence[]
  history          ClaimHistory[]
  refund           ClaimRefund?
  replacement      ClaimReplacement?

  @@index([orderId])
  @@index([storeId, status])
  @@index([buyerProfileId, status])
  @@index([status, createdAt(sort: Desc)])
  @@unique([buyerProfileId, idempotencyKey])
  @@map("order_claims")
}

model OrderClaimItem {
  id               String  @id @default(cuid())
  claimId          String  @map("claim_id")
  orderItemId      String  @map("order_item_id")
  productId        String  @map("product_id")
  quantityClaimed  Int     @map("quantity_claimed")
  quantityApproved Int?    @map("quantity_approved")
  unitPrice        Decimal @map("unit_price") @db.Decimal(10, 2)
  refundAmount     Decimal @default(0) @map("refund_amount") @db.Decimal(10, 2)

  claim     OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  orderItem OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([claimId])
  @@index([orderItemId])
  @@map("order_claim_items")
}

model ClaimEvidence {
  id        String   @id @default(cuid())
  claimId   String   @map("claim_id")
  kind      String
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  claim OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_evidence")
}

model ClaimHistory {
  id         String           @id @default(cuid())
  claimId    String           @map("claim_id")
  status     OrderClaimStatus
  actorType  ClaimActorType     @map("actor_type")
  actorId    String?            @map("actor_id")
  note       String?            @db.Text
  metadata   Json?
  createdAt  DateTime           @default(now()) @map("created_at")

  claim OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, createdAt])
  @@map("claim_history")
}

model ClaimRefund {
  id                String        @id @default(cuid())
  claimId           String        @unique @map("claim_id")
  amount            Decimal       @db.Decimal(10, 2)
  walletAmount      Decimal       @default(0) @map("wallet_amount") @db.Decimal(10, 2)
  razorpayAmount    Decimal       @default(0) @map("razorpay_amount") @db.Decimal(10, 2)
  razorpayRefundId  String?       @map("razorpay_refund_id")
  walletTxnId       String?       @map("wallet_txn_id")
  status            PaymentStatus @default(PENDING)
  idempotencyKey    String        @unique @map("idempotency_key")
  processedAt       DateTime?     @map("processed_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  claim OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_refunds")
}

model ClaimReplacement {
  id                 String    @id @default(cuid())
  claimId            String    @unique @map("claim_id")
  replacementOrderId String    @map("replacement_order_id")
  shipmentId         String?   @map("shipment_id")
  status             String    @default("PENDING")
  shippedAt          DateTime? @map("shipped_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  claim OrderClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_replacements")
}
