// =============================================================================
// IDENTITY & RBAC
// =============================================================================

model User {
  id              String     @id @default(cuid())
  email           String?    @unique
  phone           String     @unique
  passwordHash    String?    @map("password_hash")
  phoneVerified   Boolean    @default(false) @map("phone_verified")
  emailVerified   Boolean    @default(false) @map("email_verified")
  status          UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  roles           UserRole[]
  refreshTokens   RefreshToken[]
  otpVerifications OtpVerification[]
  buyerProfile    BuyerProfile?
  merchantProfile MerchantProfile?
  vendorProfile   VendorProfile?
  franchisePartner FranchisePartner?
  riderProfile    RiderProfile?
  adminProfile    AdminProfile?
  adminSessions   AdminSession[]
  adminLoginAudits AdminLoginAudit[]
  notifications   Notification[]
  reviews         Review[]
  productReviews  ProductReview[]
  auditLogs       AuditLog[]
  riskProfile     RiskProfile?
  riskEvents      RiskEvent[]
  fraudCases      FraudCase[]
  deviceFingerprints DeviceFingerprint[]
  loginSessions   LoginSession[]
  accountRestrictions AccountRestriction[]
  geoVerifications GeoVerification[]
  supportTickets    SupportTicket[]     @relation("TicketRequester")
  supportMessages   SupportMessage[]
  supportAgent      SupportAgent?
  notificationPreference NotificationPreference?
  marketingEvents       MarketingEvent[]
  segmentMemberships    CustomerSegmentMember[]
  customerJourneys      CustomerJourney[]
  journeyExecutions     JourneyExecution[]
  customerUserTags      CustomerUserTag[]
  customerAffinities      CustomerAffinity[]
  recommendationScores  RecommendationScore[]
  membershipSubscriptions MembershipSubscription[]
  corporateUsers        CorporateUser[]
  adImpressions         AdImpression[]
  adClicks              AdClick[]
  merchantApplications  MerchantApplication[]
  pushSubscriptions     PushSubscription[]

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  deviceId  String?   @map("device_id")
  deviceName String?  @map("device_name")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  rememberMe Boolean   @default(false) @map("remember_me")
  authTime   DateTime? @map("auth_time")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminSession AdminSession?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OtpVerification {
  id        String     @id @default(cuid())
  userId    String?    @map("user_id")
  phone     String
  codeHash  String     @map("code_hash")
  purpose   OtpPurpose
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  ipAddress String?    @map("ip_address")
  deviceId  String?    @map("device_id")
  userAgent String?    @map("user_agent") @db.Text
  expiresAt DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("otp_verifications")
}

// =============================================================================
// PROFILES
// =============================================================================

model BuyerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  name                 String
  avatarUrl            String?  @map("avatar_url")
  defaultAddressId     String?  @map("default_address_id")
  pushNotifications    Boolean  @default(true) @map("push_notifications")
  smsNotifications     Boolean  @default(true) @map("sms_notifications")
  codEnabled           Boolean  @default(true) @map("cod_enabled")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses    Address[]
  carts        Cart[]
  foodCarts    FoodCart[]
  orders       Order[]
  checkouts    Checkout[]
  foodCheckouts FoodCheckout[]
  wishlistItems WishlistItem[]
  reviews      Review[]
  productReviews ProductReview[]
  wallet       BuyerWallet?
  membershipSubscriptions MembershipSubscription[]
  orderClaims             OrderClaim[]

  @@map("buyer_profiles")
}

model MerchantProfile {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  businessName   String    @map("business_name")
  gstNumber      String?   @map("gst_number")
  panNumber      String?   @map("pan_number")
  kycStatus      KycStatus @default(PENDING) @map("kyc_status")
  kycDocuments   Json?     @map("kyc_documents")
  isBlacklisted  Boolean   @default(false) @map("is_blacklisted")
  blacklistReason String?  @map("blacklist_reason") @db.Text
  blacklistedAt  DateTime? @map("blacklisted_at")
  blacklistedBy  String?   @map("blacklisted_by")
  blacklistRemovedAt DateTime? @map("blacklist_removed_at")
  blacklistRemovedBy String? @map("blacklist_removed_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores Store[]
  categoryRequests MerchantCategory[]
  wallet           MerchantWallet?
  settlementLedgers SettlementLedger[]
  payoutRequests   PayoutRequest[]
  settlementConfigs SettlementConfig[]
  settlements       Settlement[]
  merchantPayouts   MerchantPayout[]
  debitNotes        DebitNote[]
  tdsRecords        TdsRecord[]
  storeNetworks     StoreNetwork[]
  inventoryTransfers InventoryTransfer[]
  procurementCarts     ProcurementCart[]
  vendorOrders         VendorOrder[]
  purchaseRecommendations PurchaseRecommendation[]
  vendorCreditLines    VendorCreditLine[]
  vendorRatings        VendorRating[]
  procurementWishlists ProcurementWishlist[]
  adCampaigns          AdCampaign[]
  merchantApplication  MerchantApplication?
  aiProductAnalyses    AIProductAnalysis[]
  aiCreditTransactions MerchantAiCreditTransaction[]
  aiWallet             MerchantAiWallet?
  aiWalletTransactions MerchantAiWalletTransaction[]

  @@index([kycStatus])
  @@index([isBlacklisted])
  @@map("merchant_profiles")
}

model MerchantApplication {
  id                String                    @id @default(cuid())
  userId            String                    @map("user_id")
  merchantProfileId String?                   @unique @map("merchant_profile_id")
  storeId           String?                   @unique @map("store_id")
  status            MerchantApplicationStatus @default(DRAFT)
  ownerName         String?                   @map("owner_name")
  ownerEmail        String?                   @map("owner_email")
  ownerPhone        String?                   @map("owner_phone")
  businessName      String?                   @map("business_name")
  businessType      MerchantBusinessType?     @map("business_type")
  gstNumber         String?                   @map("gst_number")
  gstVerified       Boolean                   @default(false) @map("gst_verified")
  panNumber         String?                   @map("pan_number")
  storeName         String?                   @map("store_name")
  storeAddress      String?                   @map("store_address") @db.Text
  pickupAddress     Json?                     @map("pickup_address")
  state             String?
  city              String?
  cityId            String?                   @map("city_id")
  pincode           String?
  locality          String?
  locationPincodeId String?                   @map("location_pincode_id")
  locationAreaId    String?                   @map("location_area_id")
  locationCityId    String?                   @map("location_city_id")
  latitude          Float?
  longitude         Float?
  deliveryRadiusKm  Float?                    @map("delivery_radius_km")
  storeLogoUrl      String?                   @map("store_logo_url") @db.Text
  storeBannerUrl         String?                   @map("store_banner_url") @db.Text
  deliveryCoveragePincodes Json?                 @map("delivery_coverage_pincodes")
  rejectionReason        String?                   @map("rejection_reason") @db.Text
  adminNotes        String?                   @map("admin_notes") @db.Text
  riskScore         Int                       @default(0) @map("risk_score")
  riskFlags         Json?                     @map("risk_flags")
  submittedAt       DateTime?                 @map("submitted_at")
  reviewedAt        DateTime?                 @map("reviewed_at")
  reviewedBy        String?                   @map("reviewed_by")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantProfile MerchantProfile?        @relation(fields: [merchantProfileId], references: [id], onDelete: SetNull)
  store           Store?                  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  documents       MerchantDocument[]
  kyc             MerchantKyc?
  bankAccount     MerchantBankAccount?
  steps           MerchantOnboardingStep[]
  businessTypes   MerchantApplicationBusinessType[]

  @@index([userId])
  @@index([status, createdAt])
  @@map("merchant_applications")
}

model MerchantDocument {
  id            String               @id @default(cuid())
  applicationId String               @map("application_id")
  documentType  MerchantDocumentType @map("document_type")
  fileName      String               @map("file_name")
  fileUrl       String               @map("file_url") @db.Text
  mimeType      String               @map("mime_type")
  uploadedAt    DateTime             @default(now()) @map("uploaded_at")

  application MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("merchant_documents")
}

model MerchantKyc {
  id            String            @id @default(cuid())
  applicationId String            @unique @map("application_id")
  status        MerchantKycStatus @default(PENDING)
  verifiedAt    DateTime?         @map("verified_at")
  verifiedBy    String?           @map("verified_by")
  notes         String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  application MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("merchant_kyc")
}

model MerchantBankAccount {
  id                String   @id @default(cuid())
  applicationId     String   @unique @map("application_id")
  accountHolderName String   @map("account_holder_name")
  accountNumber     String   @map("account_number")
  ifsc              String
  upiId             String?  @map("upi_id")
  bankName          String?  @map("bank_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  application MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("merchant_bank_accounts")
}

model MerchantOnboardingStep {
  id            String                  @id @default(cuid())
  applicationId String                  @map("application_id")
  stepKey       MerchantOnboardingStepKey @map("step_key")
  completed     Boolean                 @default(false)
  completedAt   DateTime?               @map("completed_at")
  data          Json?

  application MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, stepKey])
  @@map("merchant_onboarding_steps")
}

model RiderProfile {
  id              String      @id @default(cuid())
  userId          String      @unique @map("user_id")
  name            String
  vehicleType     VehicleType @map("vehicle_type")
  vehicleNumber   String?     @map("vehicle_number")
  licenseNumber   String?     @map("license_number")
  documents       Json?
  kycStatus       KycStatus   @default(PENDING) @map("kyc_status")
  status          RiderStatus @default(OFFLINE)
  currentLat      Float?      @map("current_lat")
  currentLng      Float?      @map("current_lng")
  currentHeading  Float?      @map("current_heading")
  currentSpeed    Float?      @map("current_speed")
  lastLocationAt  DateTime?   @map("last_location_at")
  ratingAvg       Float       @default(0) @map("rating_avg")
  ratingCount     Int         @default(0) @map("rating_count")
  totalDeliveries Int         @default(0) @map("total_deliveries")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  Delivery[]
  assignments DeliveryAssignment[]
  locations   RiderLocation[]
  trackingPoints DeliveryTracking[]
  zones       RiderZone[]
  riderPayouts RiderPayout[]
  codReconciliations CodReconciliation[]
  deliveryBatches DeliveryBatch[]
  routeOptimizations RouteOptimization[]
  fleetAlerts FleetAlert[]

  @@index([status])
  @@index([kycStatus])
  @@index([currentLat, currentLng])
  @@map("rider_profiles")
}

model AdminProfile {
  id                 String                 @id @default(cuid())
  userId             String                 @unique @map("user_id")
  name               String
  phone              String?
  department         String?
  isSuperAdmin       Boolean                @default(false) @map("is_super_admin")
  credentialSource   AdminCredentialSource  @default(DATABASE) @map("credential_source")
  failedLoginAttempts Int                   @default(0) @map("failed_login_attempts")
  lockedUntil        DateTime?              @map("locked_until")
  lastLoginAt        DateTime?              @map("last_login_at")
  passwordChangedAt  DateTime?              @map("password_changed_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

enum AdminCredentialSource {
  DATABASE
  ENV_BOOTSTRAP
}

model AdminSession {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  refreshTokenId String?   @unique @map("refresh_token_id")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent") @db.Text
  deviceName     String?   @map("device_name")
  rememberMe     Boolean   @default(false) @map("remember_me")
  lastActiveAt   DateTime  @default(now()) @map("last_active_at")
  revokedAt      DateTime? @map("revoked_at")
  loggedOutAt    DateTime? @map("logged_out_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken RefreshToken? @relation(fields: [refreshTokenId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@map("admin_sessions")
}

model AdminLoginAudit {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  email         String
  success       Boolean
  failureReason String?  @map("failure_reason")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@map("admin_login_audits")
}

model AdminSettings {
  id                String   @id @default("default")
  maxFailedAttempts Int      @default(10) @map("max_failed_attempts")
  lockoutMinutes    Int      @default(30) @map("lockout_minutes")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by")

  @@map("admin_settings")
}

model Address {
  id             String       @id @default(cuid())
  buyerProfileId String       @map("buyer_profile_id")
  label          AddressLabel @default(HOME)
  line1          String
  line2          String?
  landmark       String?
  city           String
  state          String
  pincode        String
  latitude       Float
  longitude      Float
  serviceAreaId  String?      @map("service_area_id")
  locationPincodeId String?   @map("location_pincode_id")
  locationAreaId    String?   @map("location_area_id")
  locationCityId    String?   @map("location_city_id")
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  serviceArea  ServiceArea? @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)
  locationPincode LocationPincode? @relation(fields: [locationPincodeId], references: [id], onDelete: SetNull)
  locationArea    LocationArea?    @relation(fields: [locationAreaId], references: [id], onDelete: SetNull)
  locationCity    LocationCity?    @relation(fields: [locationCityId], references: [id], onDelete: SetNull)

  @@index([buyerProfileId])
  @@index([serviceAreaId])
  @@index([locationPincodeId])
  @@index([locationCityId])
  @@index([latitude, longitude])
  @@map("addresses")
}

// =============================================================================
// GEOGRAPHY
// =============================================================================

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  state     String
  country   String   @default("IN")
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true) @map("is_active")
  timezone  String   @default("Asia/Kolkata")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zones         Zone[]
  serviceAreas  ServiceArea[]
  stores        Store[]
  vendors       Vendor[]
  franchisePartners FranchisePartner[]
  cityLaunchPlans   CityLaunchPlan[]
  seoPages          SeoPage[]
  seoFaqs           SeoFaq[]
  locationCities    LocationCity[]

  @@index([isActive])
  @@map("cities")
}

model Zone {
  id        String   @id @default(cuid())
  cityId    String   @map("city_id")
  name      String
  slug      String
  boundary  Json?
  centerLat Float    @map("center_lat")
  centerLng Float    @map("center_lng")
  radiusKm  Float    @default(5) @map("radius_km")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city         City          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  serviceAreas ServiceArea[]
  storeZones   StoreZone[]
  riderZones   RiderZone[]

  @@unique([cityId, slug])
  @@index([cityId, isActive])
  @@index([centerLat, centerLng])
  @@map("zones")
}

model ServiceArea {
  id        String   @id @default(cuid())
  cityId    String   @map("city_id")
  zoneId    String   @map("zone_id")
  name      String
  slug      String
  pincode   String?
  boundary  Json?
  centerLat Float    @map("center_lat")
  centerLng Float    @map("center_lng")
  radiusKm  Float    @default(2) @map("radius_km")
  locationAreaId String? @map("location_area_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city              City               @relation(fields: [cityId], references: [id], onDelete: Cascade)
  zone              Zone               @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locationArea      LocationArea?      @relation(fields: [locationAreaId], references: [id], onDelete: SetNull)
  addresses         Address[]
  storeServiceAreas StoreServiceArea[]

  @@unique([zoneId, slug])
  @@index([cityId, isActive])
  @@index([zoneId])
  @@index([centerLat, centerLng])
  @@map("service_areas")
}

model StoreServiceArea {
  id            String @id @default(cuid())
  storeId       String @map("store_id")
  serviceAreaId String @map("service_area_id")

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([storeId, serviceAreaId])
  @@index([serviceAreaId])
  @@map("store_service_areas")
}

/// Per-pincode delivery coverage for a merchant store.
model StoreDeliveryArea {
  id                String   @id @default(cuid())
  storeId           String   @map("store_id")
  pincode           String
  city              String?
  state             String?
  deliveryFee       Decimal? @map("delivery_fee") @db.Decimal(10, 2)
  minimumOrder      Decimal? @map("minimum_order") @db.Decimal(10, 2)
  estimatedMinutes  Int?     @map("estimated_minutes")
  priority          Int      @default(0)
  isActive          Boolean  @default(true) @map("is_active")
  locationPincodeId String?  @map("location_pincode_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  locationPincode LocationPincode? @relation(fields: [locationPincodeId], references: [id], onDelete: SetNull)

  @@unique([storeId, pincode])
  @@index([pincode])
  @@index([storeId, isActive])
  @@map("store_delivery_areas")
}

model StoreZone {
  id      String @id @default(cuid())
  storeId String @map("store_id")
  zoneId  String @map("zone_id")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  zone  Zone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([storeId, zoneId])
  @@index([zoneId])
  @@map("store_zones")
}

model RiderZone {
  id              String @id @default(cuid())
  riderProfileId  String @map("rider_profile_id")
  zoneId          String @map("zone_id")

  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  zone         Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([riderProfileId, zoneId])
  @@index([zoneId])
  @@map("rider_zones")
}

// =============================================================================
// MASTER LOCATION DIRECTORY (canonical India address hierarchy)
// =============================================================================

model LocationState {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  slug        String   @unique
  countryCode String   @default("IN") @map("country_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  districts LocationDistrict[]
  cities    LocationCity[]
  pincodes  LocationPincode[]
  aliases   LocationAlias[]

  @@index([isActive])
  @@map("location_states")
}

model LocationDistrict {
  id        String   @id @default(cuid())
  stateId   String   @map("state_id")
  name      String
  slug      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  state    LocationState    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  cities   LocationCity[]
  pincodes LocationPincode[]
  aliases  LocationAlias[]

  @@unique([stateId, slug])
  @@index([stateId, isActive])
  @@map("location_districts")
}

model LocationCity {
  id                String          @id @default(cuid())
  stateId           String          @map("state_id")
  districtId        String          @map("district_id")
  name              String
  slug              String
  deliveryRegion    DeliveryRegion? @map("delivery_region")
  latitude          Float?
  longitude         Float?
  isActive          Boolean         @default(true) @map("is_active")
  operationalCityId String?         @map("operational_city_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  state            LocationState     @relation(fields: [stateId], references: [id], onDelete: Cascade)
  district         LocationDistrict  @relation(fields: [districtId], references: [id], onDelete: Cascade)
  operationalCity  City?             @relation(fields: [operationalCityId], references: [id], onDelete: SetNull)
  areas            LocationArea[]
  pincodes         LocationPincode[]
  aliases          LocationAlias[]
  addresses        Address[]
  stores           Store[]

  @@unique([districtId, slug])
  @@index([stateId, isActive])
  @@index([deliveryRegion, isActive])
  @@index([operationalCityId])
  @@map("location_cities")
}

model LocationArea {
  id        String   @id @default(cuid())
  cityId    String   @map("city_id")
  name      String
  slug      String
  subArea   String?  @map("sub_area")
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city       LocationCity      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  pincodes   LocationPincode[]
  aliases    LocationAlias[]
  addresses  Address[]
  stores     Store[]
  serviceAreas ServiceArea[]

  @@unique([cityId, slug])
  @@index([cityId, isActive])
  @@map("location_areas")
}

/// Canonical India pincode master (PincodeMaster) — post office, city, district, state, coordinates.
model LocationPincode {
  id             String         @id @default(cuid())
  pincode        String
  stateId        String         @map("state_id")
  districtId     String         @map("district_id")
  cityId         String         @map("city_id")
  areaId         String?        @map("area_id")
  postOffice     String?        @map("post_office")
  subArea        String?        @map("sub_area")
  latitude       Float
  longitude      Float
  deliveryRegion DeliveryRegion @map("delivery_region")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  state     LocationState    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  district  LocationDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  city      LocationCity     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  area      LocationArea?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  aliases           LocationAlias[]
  addresses         Address[]
  stores            Store[]
  storeDeliveryAreas StoreDeliveryArea[]

  @@unique([pincode, postOffice])
  @@index([pincode])
  @@index([cityId, isActive])
  @@index([areaId])
  @@index([deliveryRegion, isActive])
  @@map("location_pincodes")
}

model LocationAlias {
  id         String   @id @default(cuid())
  alias      String
  slug       String   @unique
  normalized String
  stateId    String?  @map("state_id")
  districtId String?  @map("district_id")
  cityId     String?  @map("city_id")
  areaId     String?  @map("area_id")
  pincodeId  String?  @map("pincode_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  state    LocationState?    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  district LocationDistrict? @relation(fields: [districtId], references: [id], onDelete: Cascade)
  city     LocationCity?     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  area     LocationArea?     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  pincode  LocationPincode?  @relation(fields: [pincodeId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@index([isActive])
  @@map("location_aliases")
}

// =============================================================================
// STORES & CATALOG
// =============================================================================

model Store {
  id                String      @id @default(cuid())
  merchantProfileId String      @map("merchant_profile_id")
  cityId            String      @map("city_id")
  name              String
  slug              String
  description       String?
  logoUrl           String?     @map("logo_url")
  bannerUrl         String?     @map("banner_url")
  phone             String?
  email             String?
  line1             String
  line2             String?
  pincode           String
  locality          String?
  latitude          Float
  longitude         Float
  locationPincodeId String?     @map("location_pincode_id")
  locationAreaId    String?     @map("location_area_id")
  locationCityId    String?     @map("location_city_id")
  deliveryRadiusKm  Float       @default(5) @map("delivery_radius_km")
  storeType         StoreType   @default(RETAIL_STORE) @map("store_type")
  status            StoreStatus @default(DRAFT)
  submittedAt       DateTime?   @map("submitted_at")
  reviewedAt        DateTime?   @map("reviewed_at")
  reviewedBy        String?     @map("reviewed_by")
  rejectionReason         String?   @map("rejection_reason")
  rejectionType           RejectionType? @map("rejection_type")
  rejectionRevokedAt      DateTime? @map("rejection_revoked_at")
  rejectionRevokedBy      String?   @map("rejection_revoked_by")
  rejectionRevokeReason   String?   @map("rejection_revoke_reason") @db.Text
  documentRequestReason     String?   @map("document_request_reason") @db.Text
  documentRequestAt         DateTime? @map("document_request_at")
  documentRequestBy         String?   @map("document_request_by")
  requestedDocumentTypes    Json?     @map("requested_document_types")
  minOrderAmount    Decimal     @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  deliveryFee       Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  // Delivery fulfilment: PLATFORM (JebDekho arranges) or SELF (merchant's own rider, free to customer).
  deliveryMode      StoreDeliveryMode @default(PLATFORM) @map("delivery_mode")
  // Merchant-set: order subtotal at/above which the merchant gives free delivery
  // (merchant absorbs the platform delivery fee). null = no free-delivery offer.
  freeDeliveryThreshold Decimal? @map("free_delivery_threshold") @db.Decimal(10, 2)
  avgPrepTimeMins   Int         @default(15) @map("avg_prep_time_mins")
  ratingAvg         Float       @default(0) @map("rating_avg")
  ratingCount       Int         @default(0) @map("rating_count")
  reputationStats   Json?       @map("reputation_stats")
  isActive          Boolean     @default(false) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  merchantProfile   MerchantProfile    @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  city              City               @relation(fields: [cityId], references: [id], onDelete: Restrict)
  locationPincode   LocationPincode?   @relation(fields: [locationPincodeId], references: [id], onDelete: SetNull)
  locationArea      LocationArea?      @relation(fields: [locationAreaId], references: [id], onDelete: SetNull)
  locationCity      LocationCity?      @relation(fields: [locationCityId], references: [id], onDelete: SetNull)
  hours             StoreHour[]
  storeZones        StoreZone[]
  storeServiceAreas StoreServiceArea[]
  deliveryAreas     StoreDeliveryArea[]
  products          Product[]
  productSearchIndexes ProductSearchIndex[]
  categories        Category[]
  orders          Order[]
  carts           Cart[]
  coupons         Coupon[]
  storePromotions StorePromotion[]
  campaigns       Campaign[]
  offers          Offer[]
  commissionRules CommissionRule[]
  reviews         Review[]
  documentRequests       StoreDocumentRequest[]
  verificationDocuments  StoreVerificationDocument[]
  storeCategoryRequests  StoreCategoryRequest[]
  storeCategories        StoreCategory[]
  gstInvoices            GSTInvoice[]
  growthAlerts           MerchantGrowthAlert[]
  healthSnapshots        StoreHealthSnapshot[]
  storeHubs              StoreHub[]
  capacitySnapshots      StoreCapacitySnapshot[]
  transfersFrom          InventoryTransfer[] @relation("TransferFromStore")
  transfersTo            InventoryTransfer[] @relation("TransferToStore")
  fulfillmentOrders      FulfillmentOrder[]
  fulfillmentAudits      FulfillmentAudit[]
  fulfillmentDeliveries  Delivery[] @relation("DeliveryFulfillmentStore")
  franchiseStores        FranchiseStore[]
  demandForecasts        DemandForecast[]
  inventoryForecasts     InventoryForecast[]
  pricingRecommendations PricingRecommendation[]
  sponsoredStores        SponsoredStore[]
  seoPages               SeoPage[]
  seoKeywords            SeoKeyword[]
  merchantApplication    MerchantApplication?
  aiProductAnalyses      AIProductAnalysis[]
  aiCreditTransactions   MerchantAiCreditTransaction[]
  aiWalletTransactions   MerchantAiWalletTransaction[]
  businessTypes          StoreBusinessType[]
  restaurantProfile      RestaurantProfile?
  menuCategories         RestaurantMenuCategory[]
  menuItems              RestaurantMenuItem[]
  menuCombos             RestaurantCombo[]
  menuOcrJobs            MenuOcrJob[]
  foodCarts              FoodCart[]
  addonGroups            RestaurantAddonGroup[]
  orderClaims            OrderClaim[]

  @@unique([merchantProfileId, slug])
  @@index([cityId, isActive])
  @@index([locationPincodeId])
  @@index([locationCityId])
  @@index([latitude, longitude])
  @@index([status])
  @@index([status, isActive])
  @@index([status, submittedAt])
  @@map("stores")
}

model StoreDocumentRequest {
  id             String   @id @default(cuid())
  storeId        String   @map("store_id")
  reason         String   @db.Text
  documentTypes  Json     @map("document_types")
  requestedBy    String   @map("requested_by")
  requestedAt    DateTime @default(now()) @map("requested_at")
  fulfilledAt    DateTime? @map("fulfilled_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, requestedAt])
  @@map("store_document_requests")
}

model StoreVerificationDocument {
  id           String            @id @default(cuid())
  storeId      String            @map("store_id")
  documentType StoreDocumentType @map("document_type")
  fileName     String            @map("file_name")
  fileUrl      String            @map("file_url") @db.Text
  mimeType     String            @map("mime_type")
  uploadedBy   String            @map("uploaded_by")
  uploadedAt   DateTime          @default(now()) @map("uploaded_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, documentType])
  @@map("store_verification_documents")
}

model MerchantVerificationBlocklist {
  id        String                @id @default(cuid())
  type      MerchantBlocklistType
  value     String
  reason    String                @db.Text
  storeId   String?               @map("store_id")
  blockedBy String                @map("blocked_by")
  blockedAt DateTime              @default(now()) @map("blocked_at")

  @@unique([type, value])
  @@index([value])
  @@map("merchant_verification_blocklist")
}

model StoreHour {
  id        String    @id @default(cuid())
  storeId   String    @map("store_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  openTime  String    @map("open_time")
  closeTime String    @map("close_time")
  isClosed  Boolean   @default(false) @map("is_closed")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek])
  @@map("store_hours")
}

model Category {
  id          String        @id @default(cuid())
  storeId     String?       @map("store_id")
  parentId    String?       @map("parent_id")
  name        String
  slug        String
  icon        String?
  imageUrl    String?       @map("image_url")
  description String?       @db.Text
  scope       CategoryScope @default(GLOBAL)
  catalogKind CategoryCatalogKind @default(PRODUCT) @map("catalog_kind")
  sortOrder   Int           @default(0) @map("sort_order")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  store    Store?     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]
  merchantCategories MerchantCategory[]
  settlementConfigs SettlementConfig[]
  storeCategoryRequestsAsParent StoreCategoryRequest[] @relation("StoreCategoryRequestParent")
  storeCategoryRequestsAsSub    StoreCategoryRequest[] @relation("StoreCategoryRequestSub")
  storeCategoriesAsParent       StoreCategory[]        @relation("StoreCategoryParent")
  storeCategoriesAsSub          StoreCategory[]        @relation("StoreCategorySub")
  coupons                       Coupon[]
  storePromotions               StorePromotion[]
  offers                        Offer[]
  commissionRules               CommissionRule[]
  demandHotspots                DemandHotspot[]
  seoPages                      SeoPage[]
  restaurantMenuCategories      RestaurantMenuCategory[]

  @@index([storeId, isActive])
  @@index([parentId])
  @@index([catalogKind, isActive])
  @@index([deletedAt])
  @@map("categories")
}

model MerchantCategory {
  id                     String                 @id @default(cuid())
  merchantProfileId      String                 @map("merchant_profile_id")
  categoryId             String                 @map("category_id")
  status                 MerchantCategoryStatus @default(PENDING)
  requestNote            String?                @map("request_note") @db.Text
  rejectionReason        String?                @map("rejection_reason") @db.Text
  documentRequestReason  String?                @map("document_request_reason") @db.Text
  requestedDocumentTypes Json?                  @map("requested_document_types")
  submittedAt            DateTime?              @map("submitted_at")
  reviewedAt             DateTime?              @map("reviewed_at")
  reviewedBy             String?                @map("reviewed_by")
  rejectionRevokedAt     DateTime?              @map("rejection_revoked_at")
  rejectionRevokedBy     String?                @map("rejection_revoked_by")
  rejectionRevokeReason  String?                @map("rejection_revoke_reason") @db.Text
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  merchantProfile MerchantProfile            @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  category        Category                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  documents       MerchantCategoryDocument[]

  @@unique([merchantProfileId, categoryId])
  @@index([merchantProfileId, status])
  @@index([status])
  @@map("merchant_categories")
}

model MerchantCategoryDocument {
  id                 String            @id @default(cuid())
  merchantCategoryId String            @map("merchant_category_id")
  documentType       StoreDocumentType @map("document_type")
  fileName           String            @map("file_name")
  fileUrl            String            @map("file_url") @db.Text
  mimeType           String            @map("mime_type")
  uploadedBy         String            @map("uploaded_by")
  uploadedAt         DateTime          @default(now()) @map("uploaded_at")

  merchantCategory MerchantCategory @relation(fields: [merchantCategoryId], references: [id], onDelete: Cascade)

  @@index([merchantCategoryId])
  @@map("merchant_category_documents")
}

model StoreCategoryRequest {
  id            String                     @id @default(cuid())
  storeId       String                     @map("store_id")
  categoryId    String                     @map("category_id")
  subcategoryId String                     @map("subcategory_id")
  status        StoreCategoryRequestStatus @default(PENDING)
  reason        String?                    @db.Text
  adminNote     String?                    @map("admin_note") @db.Text
  reviewedBy    String?                    @map("reviewed_by")
  reviewedAt    DateTime?                  @map("reviewed_at")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category @relation("StoreCategoryRequestParent", fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory Category @relation("StoreCategoryRequestSub", fields: [subcategoryId], references: [id], onDelete: Restrict)
  documents   StoreCategoryRequestDocument[]

  @@unique([storeId, categoryId, subcategoryId])
  @@index([storeId, status])
  @@index([status])
  @@map("store_category_requests")
}

model StoreCategory {
  id            String   @id @default(cuid())
  storeId       String   @map("store_id")
  categoryId    String   @map("category_id")
  subcategoryId String   @map("subcategory_id")
  approvedBy    String?  @map("approved_by")
  approvedAt    DateTime @default(now()) @map("approved_at")

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category @relation("StoreCategoryParent", fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory Category @relation("StoreCategorySub", fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@unique([storeId, categoryId, subcategoryId])
  @@index([storeId])
  @@index([categoryId])
  @@map("store_categories")
}

model StoreCategoryRequestDocument {
  id                     String            @id @default(cuid())
  storeCategoryRequestId String            @map("store_category_request_id")
  documentType           StoreDocumentType @map("document_type")
  fileName               String            @map("file_name")
  fileUrl                String            @map("file_url") @db.Text
  mimeType               String            @map("mime_type")
  uploadedBy             String            @map("uploaded_by")
  uploadedAt             DateTime          @default(now()) @map("uploaded_at")

  storeCategoryRequest StoreCategoryRequest @relation(fields: [storeCategoryRequestId], references: [id], onDelete: Cascade)

  @@index([storeCategoryRequestId])
  @@map("store_category_request_documents")
}

model Product {
  id          String    @id @default(cuid())
  storeId     String    @map("store_id")
  categoryId  String?   @map("category_id")
  name        String
  slug        String
  description String?
  imageUrls   String[]  @map("image_urls")
  basePrice   Decimal   @map("base_price") @db.Decimal(10, 2)
  mrp         Decimal?  @db.Decimal(10, 2)
  brand       String?
  sku         String?
  unit        String    @default("piece")
  weightGrams Int?      @map("weight_grams")
  tags        String[]  @default([])
  isVeg       Boolean?  @map("is_veg")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  hsnCodeId   String?   @map("hsn_code_id")
  gstSlab     GstSlab?  @map("gst_slab")
  taxCategory ProductTaxCategory @default(GOODS) @map("tax_category")
  taxInclusive Boolean  @default(false) @map("tax_inclusive")
  ingredients          String?   @db.Text
  shelfLife            String?   @map("shelf_life")
  countryOfOrigin      String?   @map("country_of_origin")
  manufacturerName     String?   @map("manufacturer_name")
  manufacturerAddress  String?   @map("manufacturer_address") @db.Text
  fssaiLicense         String?   @map("fssai_license")
  // ── Electronics / gadgets ────────────────────────────────────────────────
  modelNumber          String?   @map("model_number")
  warrantyMonths       Int?      @map("warranty_months")
  // Structured spec sheet: array of { label, value } (RAM, Storage, Battery, …).
  specifications       Json?
  storageInstructions  String?   @map("storage_instructions") @db.Text
  disclaimer           String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  store         Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  hsnCodeRef    HSNCode?         @relation(fields: [hsnCodeId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  coupons       Coupon[]
  storePromotions StorePromotion[]
  offers        Offer[]
  searchIndex   ProductSearchIndex?
  inventoryReservations InventoryReservation[]
  demandForecasts       DemandForecast[]
  inventoryForecasts    InventoryForecast[]
  pricingRecommendations PricingRecommendation[]
  sponsoredProducts      SponsoredProduct[]
  productReviews         ProductReview[]
  aiProductAnalysis      AIProductAnalysis?
  orderClaimItems        OrderClaimItem[]

  // Merchant-controlled return / refund / replacement policy
  isReturnable              Boolean               @default(false) @map("is_returnable")
  isRefundable              Boolean               @default(false) @map("is_refundable")
  isReplaceable             Boolean               @default(false) @map("is_replaceable")
  returnWindowHours         Int?                  @map("return_window_hours")
  approvalMode              ClaimApprovalMode     @default(MANUAL) @map("approval_mode")
  proofRequired             ClaimProofRequirement @default(NONE) @map("proof_required")
  autoApproveBelowAmount    Decimal?              @map("auto_approve_below_amount") @db.Decimal(10, 2)
  returnReasons             ReturnClaimReason[]   @default([]) @map("return_reasons")
  restockingFee             Decimal               @default(0) @map("restocking_fee") @db.Decimal(10, 2)
  refundMethod              ClaimRefundMethod     @default(ORIGINAL_PAYMENT) @map("refund_method")
  returnPolicyText          String?               @map("return_policy_text") @db.Text
  replacementPolicyText     String?               @map("replacement_policy_text") @db.Text
  preparedFoodPolicy          PreparedFoodPolicy?   @map("prepared_food_policy")
  allowCustomerChangedMind    Boolean             @default(false) @map("allow_customer_changed_mind")

  @@unique([storeId, slug])
  @@index([storeId, isActive])
  @@index([categoryId])
  @@index([name])
  @@map("products")
}

model ProductSearchIndex {
  id           String   @id @default(cuid())
  productId    String   @unique @map("product_id")
  storeId      String   @map("store_id")
  name         String
  description  String?
  categoryName String?  @map("category_name")
  brand        String?
  tags         String[] @default([])
  searchText   String   @map("search_text")
  isActive     Boolean  @default(true) @map("is_active")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@index([searchText])
  @@map("product_search_index")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  sku       String
  name      String
  price     Decimal  @db.Decimal(10, 2)
  mrp       Decimal? @db.Decimal(10, 2)
  weightGrams Int?   @map("weight_grams")
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product      Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory    Inventory?
  cartItems    CartItem[]
  orderItems   OrderItem[]
  reservations InventoryReservation[]
  transferItems TransferItem[]
  fulfillmentOrderItems FulfillmentOrderItem[]

  @@unique([productId, sku])
  @@index([productId])
  @@map("product_variants")
}

model Inventory {
  id                String          @id @default(cuid())
  variantId         String          @unique @map("variant_id")
  availableQty      Int             @default(0) @map("quantity")
  reservedQty       Int             @default(0) @map("reserved")
  soldQty           Int             @default(0) @map("sold_qty")
  lowStockThreshold Int             @default(5) @map("low_stock_threshold")
  status            InventoryStatus @default(ACTIVE)
  version           Int             @default(0)
  updatedAt         DateTime        @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([availableQty])
  @@index([status])
  @@map("inventory")
}

// =============================================================================
// CART & WISHLIST
// =============================================================================

model Cart {
  id                  String   @id @default(cuid())
  buyerProfileId      String   @map("buyer_profile_id")
  storeId             String   @map("store_id")
  appliedCouponId     String?  @map("applied_coupon_id")
  appliedPromotionId  String?  @map("applied_promotion_id")
  appliedOfferId      String?  @map("applied_offer_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  buyerProfile     BuyerProfile     @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  appliedCoupon    Coupon?          @relation(fields: [appliedCouponId], references: [id], onDelete: SetNull)
  appliedPromotion StorePromotion?  @relation(fields: [appliedPromotionId], references: [id], onDelete: SetNull)
  appliedOffer     Offer?           @relation(fields: [appliedOfferId], references: [id], onDelete: SetNull)
  items            CartItem[]

  @@unique([buyerProfileId, storeId])
  @@index([buyerProfileId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  variantId String   @map("variant_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id             String   @id @default(cuid())
  buyerProfileId String   @map("buyer_profile_id")
  productId      String   @map("product_id")
  createdAt      DateTime @default(now()) @map("created_at")

  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buyerProfileId, productId])
  @@index([buyerProfileId])
  @@map("wishlist_items")
}

// =============================================================================
// CHECKOUT & RESERVATIONS (Phase 6)
// =============================================================================

model Checkout {
  id              String         @id @default(cuid())
  buyerProfileId  String         @map("buyer_profile_id")
  storeId         String         @map("store_id")
  orderId         String?        @unique @map("order_id")
  status          CheckoutStatus @default(INITIATED)
  cartSnapshot    Json           @map("cart_snapshot")
  totalAmount     Decimal        @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress Json           @map("delivery_address")
  deliveryLat     Float          @map("delivery_lat")
  deliveryLng     Float          @map("delivery_lng")
  buyerNote       String?        @map("buyer_note")
  idempotencyKey  String?        @unique @map("idempotency_key")
  expiresAt       DateTime       @map("expires_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  buyerProfile BuyerProfile          @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  order        Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  reservations InventoryReservation[]

  @@index([buyerProfileId, status])
  @@index([status, expiresAt])
  @@map("checkouts")
}

model InventoryReservation {
  id         String            @id @default(cuid())
  checkoutId String            @map("checkout_id")
  orderId    String?           @map("order_id")
  productId  String?           @map("product_id")
  variantId  String            @map("variant_id")
  quantity   Int
  status     ReservationStatus @default(ACTIVE)
  expiresAt  DateTime          @map("expires_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  checkout Checkout       @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  order    Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product  Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([status, expiresAt])
  @@index([checkoutId])
  @@index([orderId])
  @@index([variantId])
  @@map("inventory_reservations")
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String   @unique
  userId       String   @map("user_id")
  endpoint     String
  responseCode Int      @map("response_code")
  responseBody Json     @map("response_body")
  processing   Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// =============================================================================
// ORDERS
// =============================================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @map("order_number")
  buyerProfileId  String      @map("buyer_profile_id")
  storeId         String         @map("store_id")
  status          OrderStatus    @default(CREATED)
  paymentMethod   PaymentMethod  @map("payment_method")
  paymentStatus   PaymentStatus  @default(PENDING) @map("payment_status")
  subtotal        Decimal        @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  // Delivery fulfilment snapshot (frozen at checkout for correct payout).
  deliveryMode    StoreDeliveryMode @default(PLATFORM) @map("delivery_mode")
  // Platform delivery fee the merchant absorbs (order ≥ their free-delivery
  // threshold). Deducted from merchant payout so the platform never subsidises.
  merchantDeliveryContribution Decimal @default(0) @map("merchant_delivery_contribution") @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  walletAmountUsed Decimal    @default(0) @map("wallet_amount_used") @db.Decimal(10, 2)
  rewardPointsUsed Int        @default(0) @map("reward_points_used")
  rewardPointsEarned Int      @default(0) @map("reward_points_earned")
  razorpayAmount  Decimal?    @map("razorpay_amount") @db.Decimal(10, 2)
  couponId        String?     @map("coupon_id")
  deliveryAddress Json        @map("delivery_address")
  deliveryLat     Float       @map("delivery_lat")
  deliveryLng     Float       @map("delivery_lng")
  isSplitFulfillment Boolean  @default(false) @map("is_split_fulfillment")
  buyerNote       String?     @map("buyer_note")
  orderVertical   OrderVertical @default(GROCERY) @map("order_vertical")
  packagingFee    Decimal     @default(0) @map("packaging_fee") @db.Decimal(10, 2)
  tipAmount       Decimal     @default(0) @map("tip_amount") @db.Decimal(10, 2)
  scheduledDeliveryAt DateTime? @map("scheduled_delivery_at")
  specialInstructions String? @map("special_instructions") @db.Text
  restaurantNote  String?     @map("restaurant_note") @db.Text
  kitchenStatus   FoodKitchenStatus? @map("kitchen_status")
  cancelReason    String?     @map("cancel_reason")
  idempotencyKey  String?     @unique @map("idempotency_key")
  paidAt          DateTime?   @map("paid_at")
  completedAt     DateTime?   @map("completed_at")
  cancelledAt     DateTime?   @map("cancelled_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  buyerProfile  BuyerProfile         @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  store         Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  coupon        Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  foodItems     FoodOrderItem[]
  statusHistory OrderStatusHistory[]
  payment       Payment?
  delivery      Delivery?
  couponUsage   CouponUsage?
  promotionUsage PromotionUsage?
  review        Review?
  productReviews ProductReview[]
  checkout      Checkout?
  settlementLedger SettlementLedger?
  inventoryReservations InventoryReservation[]
  financialSnapshot OrderFinancialSnapshot?
  ledgerJournals    LedgerJournal[]
  settlementItems   SettlementItem[]
  taxRecords        TaxRecord[]
  codReconciliations CodReconciliation[]
  gstInvoice        GSTInvoice?
  creditNotes       CreditNote[]
  fulfillmentOrders FulfillmentOrder[]
  fulfillmentAudits FulfillmentAudit[]
  deliveryBatchItem DeliveryBatchItem?
  providerShipment  ProviderShipment?
  adConversions     AdConversion[]
  membershipUsages  MembershipUsage[]
  corporatePurchaseRequests PurchaseRequest[]
  claims                  OrderClaim[]
  orderRefunds            OrderRefund[]

  @@index([buyerProfileId, status])
  @@index([storeId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([paymentMethod, paymentStatus])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  variantId   String  @map("variant_id")
  productName String  @map("product_name")
  variantName String  @map("variant_name")
  sku         String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  tax         Decimal @default(0) @db.Decimal(10, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  fulfillmentItems FulfillmentOrderItem[]
  productReviews ProductReview[]
  claimItems     OrderClaimItem[]

  @@index([orderId])
  @@map("order_items")
}

model FoodOrderItem {
  id                  String  @id @default(cuid())
  orderId             String  @map("order_id")
  menuItemId          String  @map("menu_item_id")
  variantId           String? @map("variant_id")
  itemName            String  @map("item_name")
  variantName         String? @map("variant_name")
  quantity            Int
  unitPrice           Decimal @map("unit_price") @db.Decimal(10, 2)
  discount            Decimal @default(0) @db.Decimal(10, 2)
  tax                 Decimal @default(0) @db.Decimal(10, 2)
  totalPrice          Decimal @map("total_price") @db.Decimal(10, 2)
  specialInstructions String? @map("special_instructions") @db.Text
  addonsSnapshot      Json?   @map("addons_snapshot")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("food_order_items")
}

model OrderStatusHistory {
  id        String          @id @default(cuid())
  orderId   String          @map("order_id")
  status    OrderStatus
  note      String?
  changedBy String?         @map("changed_by")
  actorType OrderActorType  @default(SYSTEM) @map("actor_type")
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

// =============================================================================
// PAYMENTS
// =============================================================================

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique @map("order_id")
  razorpayOrderId   String?       @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpaySignature String?       @map("razorpay_signature")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  method            PaymentMethod @default(RAZORPAY)
  status            PaymentStatus @default(PENDING)
  failureReason     String?       @map("failure_reason")
  metadata          Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order        Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]

  @@index([status])
  @@map("payments")
}

model PaymentTransaction {
  id              String        @id @default(cuid())
  paymentId       String        @map("payment_id")
  type            String
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus
  razorpayRefundId String?      @map("razorpay_refund_id")
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_transactions")
}

// =============================================================================
// DELIVERY & RIDERS
// =============================================================================

model Delivery {
  id              String         @id @default(cuid())
  orderId         String         @unique @map("order_id")
  riderProfileId  String?        @map("rider_profile_id")
  fulfillmentStoreId String?     @map("fulfillment_store_id")
  status          DeliveryStatus @default(PENDING)
  pickupLat       Float          @map("pickup_lat")
  pickupLng       Float          @map("pickup_lng")
  deliveryLat     Float          @map("delivery_lat")
  deliveryLng     Float          @map("delivery_lng")
  distanceKm      Float?         @map("distance_km")
  estimatedMins   Int?           @map("estimated_mins")
  estimatedArrivalAt DateTime?   @map("estimated_arrival_at")
  assignedAt      DateTime?      @map("assigned_at")
  assignedBy      String?        @map("assigned_by")
  arrivedAtStoreAt DateTime?     @map("arrived_at_store_at")
  pickedUpAt      DateTime?      @map("picked_up_at")
  arrivedAtCustomerAt DateTime? @map("arrived_at_customer_at")
  deliveredAt     DateTime?      @map("delivered_at")
  deliveryProofUrl String?       @map("delivery_proof_url")
  riderEarning    Decimal?       @map("rider_earning") @db.Decimal(10, 2)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  order             Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  fulfillmentStore  Store?               @relation("DeliveryFulfillmentStore", fields: [fulfillmentStoreId], references: [id], onDelete: SetNull)
  riderProfile      RiderProfile?        @relation(fields: [riderProfileId], references: [id], onDelete: SetNull)
  assignments  DeliveryAssignment[]
  trackingPoints DeliveryTracking[]
  riderPayoutItems RiderPayoutItem[]
  providerShipment ProviderShipment?

  @@index([riderProfileId, status])
  @@index([status])
  @@map("deliveries")
}

model DeliveryTracking {
  id             String   @id @default(cuid())
  deliveryId     String   @map("delivery_id")
  riderProfileId String   @map("rider_profile_id")
  lat            Float
  lng            Float
  heading        Float?
  speed          Float?
  accuracy       Float?
  recordedAt     DateTime @default(now()) @map("recorded_at")

  delivery     Delivery     @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)

  @@index([deliveryId, recordedAt(sort: Desc)])
  @@index([riderProfileId, recordedAt(sort: Desc)])
  @@index([recordedAt])
  @@map("delivery_tracking")
}

model DeliveryAssignment {
  id             String           @id @default(cuid())
  deliveryId     String           @map("delivery_id")
  riderProfileId String           @map("rider_profile_id")
  status         AssignmentStatus @default(OFFERED)
  offeredAt      DateTime         @default(now()) @map("offered_at")
  respondedAt    DateTime?        @map("responded_at")
  expiresAt      DateTime         @map("expires_at")
  assignedBy     String?          @map("assigned_by")

  delivery     Delivery     @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)

  @@index([riderProfileId, status])
  @@index([deliveryId])
  @@map("delivery_assignments")
}

model RiderLocation {
  id             String   @id @default(cuid())
  riderProfileId String   @map("rider_profile_id")
  latitude       Float
  longitude      Float
  heading        Float?
  speed          Float?
  accuracy       Float?
  recordedAt     DateTime @default(now()) @map("recorded_at")

  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)

  @@index([riderProfileId, recordedAt(sort: Desc)])
  @@map("rider_locations")
}

// =============================================================================
// COUPONS & REVIEWS
// =============================================================================

model Coupon {
  id             String      @id @default(cuid())
  code           String      @unique
  name           String
  description    String?
  type           CouponType
  kind           CouponKind  @default(GENERIC)
  scope          CouponScope @default(PLATFORM)
  sponsor        OfferSponsor @default(PLATFORM)
  storeId        String?     @map("store_id")
  categoryId     String?     @map("category_id")
  productId      String?     @map("product_id")
  discountValue  Decimal     @map("discount_value") @db.Decimal(10, 2)
  maxDiscount    Decimal?    @map("max_discount") @db.Decimal(10, 2)
  minOrderAmount Decimal     @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  usageLimit     Int?        @map("usage_limit")
  usedCount      Int         @default(0) @map("used_count")
  perUserLimit   Int         @default(1) @map("per_user_limit")
  firstOrderOnly Boolean     @default(false) @map("first_order_only")
  startsAt       DateTime    @map("starts_at")
  expiresAt      DateTime    @map("expires_at")
  isActive       Boolean     @default(true) @map("is_active")
  suspendedAt    DateTime?   @map("suspended_at")
  suspendedBy    String?     @map("suspended_by")
  createdById    String?     @map("created_by_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  store    Store?        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product  Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  orders   Order[]
  usages   CouponUsage[]
  carts    Cart[]
  foodCarts FoodCart[]

  @@index([storeId, isActive])
  @@index([categoryId])
  @@index([expiresAt])
  @@index([kind, isActive])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String   @map("coupon_id")
  orderId        String   @unique @map("order_id")
  buyerProfileId String   @map("buyer_profile_id")
  discountApplied Decimal @map("discount_applied") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([couponId])
  @@index([buyerProfileId])
  @@map("coupon_usages")
}

model StorePromotion {
  id             String             @id @default(cuid())
  storeId        String             @map("store_id")
  name           String
  description    String?
  offerType      PromotionOfferType @map("offer_type")
  target         PromotionTarget    @default(STORE_WIDE)
  categoryId     String?            @map("category_id")
  productId      String?            @map("product_id")
  discountValue  Decimal            @map("discount_value") @db.Decimal(10, 2)
  buyQuantity    Int?               @map("buy_quantity")
  getQuantity    Int?               @map("get_quantity")
  minOrderAmount Decimal            @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscount    Decimal?           @map("max_discount") @db.Decimal(10, 2)
  usageLimit     Int?               @map("usage_limit")
  usedCount      Int                @default(0) @map("used_count")
  startsAt       DateTime           @map("starts_at")
  expiresAt      DateTime           @map("expires_at")
  isActive       Boolean            @default(true) @map("is_active")
  pausedAt       DateTime?          @map("paused_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  store      Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product    Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  carts      Cart[]
  usages     PromotionUsage[]

  @@index([storeId, isActive])
  @@index([storeId, expiresAt])
  @@index([offerType])
  @@map("store_promotions")
}

model PromotionUsage {
  id              String   @id @default(cuid())
  promotionId     String   @map("promotion_id")
  orderId         String   @unique @map("order_id")
  buyerProfileId  String   @map("buyer_profile_id")
  discountApplied Decimal  @map("discount_applied") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  promotion StorePromotion @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([promotionId])
  @@index([buyerProfileId])
  @@map("promotion_usages")
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  REMOVED
  REPORTED
}

model Review {
  id                 String       @id @default(cuid())
  orderId            String       @unique @map("order_id")
  buyerProfileId     String       @map("buyer_profile_id")
  storeId            String       @map("store_id")
  productId          String?      @map("product_id")
  userId             String       @map("user_id")
  rating             Int
  storeExperience    Int          @default(5) @map("store_experience")
  deliveryExperience Int          @default(5) @map("delivery_experience")
  productQuality     Int          @default(5) @map("product_quality")
  title              String?
  comment            String?      @db.Text
  images             String[]     @default([])
  verifiedPurchase   Boolean      @default(true) @map("verified_purchase")
  merchantReply      String?      @map("merchant_reply") @db.Text
  merchantRepliedAt  DateTime?    @map("merchant_replied_at")
  status             ReviewStatus @default(VISIBLE)
  reportedAt         DateTime?    @map("reported_at")
  reportReason       String?      @map("report_reason") @db.Text
  moderatedBy        String?      @map("moderated_by")
  moderatedAt        DateTime?    @map("moderated_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  buyerProfile BuyerProfile  @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)

  @@index([storeId, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([productId])
  @@index([status])
  @@map("reviews")
}

model ProductReview {
  id               String       @id @default(cuid())
  productId        String       @map("product_id")
  userId           String       @map("user_id")
  buyerProfileId   String       @map("buyer_profile_id")
  orderId          String       @map("order_id")
  orderItemId      String?      @map("order_item_id")
  rating           Int
  comment          String?      @db.Text
  images           String[]     @default([])
  verifiedPurchase Boolean      @default(true) @map("verified_purchase")
  status           ReviewStatus @default(VISIBLE)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  buyerProfile BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Restrict)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderItem    OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@unique([userId, productId])
  @@index([productId, status])
  @@index([productId, createdAt(sort: Desc)])
  @@map("product_reviews")
}

// =============================================================================
// PLATFORM — EVENTS, AUDIT, NOTIFICATIONS
// =============================================================================

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("platform_settings")
}

model DomainEvent {
  id            String          @id @default(cuid())
  eventType     DomainEventType @map("event_type")
  aggregateType String          @map("aggregate_type")
  aggregateId   String          @map("aggregate_id")
  payload       Json
  metadata      Json?
  occurredAt    DateTime        @default(now()) @map("occurred_at")
  processedAt   DateTime?       @map("processed_at")

  @@index([eventType, occurredAt(sort: Desc)])
  @@index([aggregateType, aggregateId])
  @@index([processedAt])
  @@map("domain_events")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model NotificationTemplate {
  id        String              @id @default(cuid())
  code      String              @unique
  channel   NotificationChannel
  name      String
  category  String              @default("GENERAL")
  subject   String?
  body      String
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  deliveries NotificationDelivery[]

  @@index([channel, isActive])
  @@map("notification_templates")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String?                    @map("notification_id")
  userId         String                     @map("user_id")
  templateId     String?                    @map("template_id")
  channel        NotificationChannel
  recipient      String
  subject        String?
  body           String
  status         NotificationDeliveryStatus @default(PENDING)
  providerRef    String?                    @map("provider_ref")
  errorMessage   String?                    @map("error_message")
  metadata       Json?
  queuedAt       DateTime?                  @map("queued_at")
  sentAt         DateTime?                  @map("sent_at")
  deliveredAt    DateTime?                  @map("delivered_at")
  failedAt       DateTime?                  @map("failed_at")
  createdAt      DateTime                   @default(now()) @map("created_at")

  notification Notification?         @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  template     NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([channel, status])
  @@index([status, createdAt])
  @@map("notification_deliveries")
}

// =============================================================================
// BUYER WALLET & LOYALTY (P3.5)
// =============================================================================

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  REWARD_CREDIT
  ADMIN_ADJUSTMENT
  EXPIRY
}

enum WalletLedgerEntryType {
  DEBIT
  CREDIT
}

enum RewardTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUSTMENT
  REFERRAL_BONUS
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ReferralStatus {
  PENDING
  COMPLETED
  REJECTED
  FRAUD_FLAGGED
}

enum WalletFraudReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model BuyerWallet {
  id                String       @id @default(cuid())
  buyerProfileId    String       @unique @map("buyer_profile_id")
  balance           Decimal      @default(0) @db.Decimal(12, 2)
  rewardPoints      Int          @default(0) @map("reward_points")
  lifetimePoints    Int          @default(0) @map("lifetime_points")
  tier              LoyaltyTier  @default(BRONZE)
  referralCode      String       @unique @map("referral_code")
  referredById      String?      @map("referred_by_id")
  deviceFingerprint String?      @map("device_fingerprint")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  buyerProfile      BuyerProfile        @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  referredBy        BuyerWallet?        @relation("ReferralChain", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         BuyerWallet[]       @relation("ReferralChain")
  transactions      WalletTransaction[]
  ledgerEntries     WalletLedgerEntry[]
  rewardTransactions RewardTransaction[]
  referralsGiven    Referral[]          @relation("ReferrerWallet")
  referralReceived  Referral?           @relation("ReferredWallet")
  fraudReviews      WalletFraudReview[]

  @@index([tier])
  @@map("buyer_wallets")
}

model WalletTransaction {
  id             String                @id @default(cuid())
  walletId       String                @map("wallet_id")
  type           WalletTransactionType
  amount         Decimal               @db.Decimal(12, 2)
  balanceAfter   Decimal               @map("balance_after") @db.Decimal(12, 2)
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id")
  description    String?
  expiresAt      DateTime?             @map("expires_at")
  idempotencyKey String?               @unique @map("idempotency_key")
  createdBy      String?               @map("created_by")
  createdAt      DateTime              @default(now()) @map("created_at")

  wallet        BuyerWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerEntries WalletLedgerEntry[]

  @@index([walletId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model WalletLedgerEntry {
  id            String                @id @default(cuid())
  walletId      String                @map("wallet_id")
  transactionId String                @map("transaction_id")
  entryType     WalletLedgerEntryType @map("entry_type")
  amount        Decimal               @db.Decimal(12, 2)
  balanceBefore Decimal               @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal               @map("balance_after") @db.Decimal(12, 2)
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at")

  wallet      BuyerWallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction WalletTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@map("wallet_ledger_entries")
}

model RewardTransaction {
  id             String                @id @default(cuid())
  walletId       String                @map("wallet_id")
  type           RewardTransactionType
  points         Int
  pointsAfter    Int                   @map("points_after")
  orderId        String?               @unique @map("order_id")
  referenceId    String?               @map("reference_id")
  description    String?
  expiresAt      DateTime?             @map("expires_at")
  idempotencyKey String?               @unique @map("idempotency_key")
  createdAt      DateTime              @default(now()) @map("created_at")

  wallet BuyerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@map("reward_transactions")
}

model Referral {
  id                   String         @id @default(cuid())
  referrerWalletId     String         @map("referrer_wallet_id")
  referredWalletId     String         @unique @map("referred_wallet_id")
  status               ReferralStatus @default(PENDING)
  referrerRewardPoints Int?           @map("referrer_reward_points")
  referredRewardPoints Int?           @map("referred_reward_points")
  referrerWalletCredit Decimal?       @map("referrer_wallet_credit") @db.Decimal(10, 2)
  referredWalletCredit Decimal?       @map("referred_wallet_credit") @db.Decimal(10, 2)
  deviceFingerprint    String?        @map("device_fingerprint")
  completedAt          DateTime?      @map("completed_at")
  createdAt            DateTime       @default(now()) @map("created_at")

  referrer BuyerWallet @relation("ReferrerWallet", fields: [referrerWalletId], references: [id], onDelete: Cascade)
  referred BuyerWallet @relation("ReferredWallet", fields: [referredWalletId], references: [id], onDelete: Cascade)

  @@index([referrerWalletId])
  @@index([status])
  @@map("referrals")
}

model RewardProgramConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reward_program_configs")
}

model WalletFraudReview {
  id             String                  @id @default(cuid())
  walletId       String                  @map("wallet_id")
  reviewType     String                  @map("review_type")
  status         WalletFraudReviewStatus @default(PENDING)
  metadata       Json?
  reviewedBy     String?                 @map("reviewed_by")
  reviewedAt     DateTime?               @map("reviewed_at")
  createdAt      DateTime                @default(now()) @map("created_at")

  wallet BuyerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@map("wallet_fraud_reviews")
}

// =============================================================================
// MERCHANT SETTLEMENTS
// =============================================================================

model MerchantWallet {
  id                String   @id @default(cuid())
  merchantProfileId String   @unique @map("merchant_profile_id")
  availableBalance  Decimal  @default(0) @map("available_balance") @db.Decimal(12, 2)
  pendingBalance    Decimal  @default(0) @map("pending_balance") @db.Decimal(12, 2)
  totalEarned       Decimal  @default(0) @map("total_earned") @db.Decimal(12, 2)
  totalPaidOut      Decimal  @default(0) @map("total_paid_out") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)

  @@map("merchant_wallets")
}

model SettlementLedger {
  id                  String                 @id @default(cuid())
  merchantProfileId   String                 @map("merchant_profile_id")
  orderId             String                 @unique @map("order_id")
  grossAmount         Decimal                @map("gross_amount") @db.Decimal(12, 2)
  deliveryFee         Decimal                @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  platformCommission  Decimal                @map("platform_commission") @db.Decimal(12, 2)
  taxAmount           Decimal                @default(0) @map("tax_amount") @db.Decimal(12, 2)
  netAmount           Decimal                @map("net_amount") @db.Decimal(12, 2)
  commissionPercent   Decimal                @map("commission_percent") @db.Decimal(5, 2)
  status              SettlementLedgerStatus @default(PENDING)
  eligibleAt          DateTime               @map("eligible_at")
  settledAt           DateTime?              @map("settled_at")
  payoutRequestId     String?                @map("payout_request_id")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payoutRequest   PayoutRequest?  @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)
  settlementItems SettlementItem[]

  @@index([merchantProfileId, status])
  @@index([status, eligibleAt])
  @@index([createdAt(sort: Desc)])
  @@map("settlement_ledger")
}

model PayoutRequest {
  id                  String              @id @default(cuid())
  merchantProfileId   String              @map("merchant_profile_id")
  amount              Decimal             @db.Decimal(12, 2)
  status              PayoutRequestStatus @default(PENDING)
  bankDetailsSnapshot Json                @map("bank_details_snapshot")
  rejectionReason     String?             @map("rejection_reason") @db.Text
  requestedAt         DateTime            @default(now()) @map("requested_at")
  reviewedAt          DateTime?           @map("reviewed_at")
  reviewedBy          String?             @map("reviewed_by")
  processedAt         DateTime?           @map("processed_at")
  processedBy         String?             @map("processed_by")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  merchantProfile MerchantProfile    @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  ledgerEntries   SettlementLedger[]
  transactions    PayoutTransaction[]
  merchantPayout  MerchantPayout?

  @@index([merchantProfileId, status])
  @@index([status, requestedAt])
  @@map("payout_requests")
}

model PayoutTransaction {
  id              String                  @id @default(cuid())
  payoutRequestId String                  @map("payout_request_id")
  amount          Decimal                 @db.Decimal(12, 2)
  status          PayoutTransactionStatus @default(PENDING)
  referenceId     String?                 @map("reference_id")
  failureReason   String?                 @map("failure_reason") @db.Text
  processedAt     DateTime?               @map("processed_at")
  createdAt       DateTime                @default(now()) @map("created_at")

  payoutRequest PayoutRequest @relation(fields: [payoutRequestId], references: [id], onDelete: Cascade)

  @@index([payoutRequestId])
  @@map("payout_transactions")
}

model SettlementConfig {
  id                  String                @id @default(cuid())
  scope               SettlementConfigScope
  merchantProfileId   String?               @map("merchant_profile_id")
  categoryId          String?               @map("category_id")
  commissionPercent   Decimal               @map("commission_percent") @db.Decimal(5, 2)
  settlementDelayDays Int                   @default(2) @map("settlement_delay_days")
  isActive            Boolean               @default(true) @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  merchantProfile MerchantProfile? @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([scope, isActive])
  @@index([merchantProfileId])
  @@index([categoryId])
  @@map("settlement_configs")
}

