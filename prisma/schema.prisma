// How a store fulfils delivery.
//  PLATFORM = JebDekho arranges delivery (Shadowfax / own fleet); customer pays
//             the platform delivery fee (or the merchant absorbs it above their
//             free-delivery threshold).
//  SELF     = merchant delivers with their own rider; delivery is FREE to the
//             customer and the platform does not dispatch a shipment.
enum StoreDeliveryMode {
  PLATFORM
  SELF
}

