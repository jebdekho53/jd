// =============================================================================
// CAMPAIGNS & DYNAMIC OFFERS (P4.3)
// =============================================================================

enum CampaignScope {
  PLATFORM
  MERCHANT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ENDED
}

enum OfferStackMode {
  BEST_OFFER
  STACKABLE
}

enum OfferKind {
  FLAT_DISCOUNT
  PERCENTAGE_DISCOUNT
  BUY_X_GET_Y
  COMBO_BUNDLE
  CATEGORY_DISCOUNT
  STORE_WIDE_DISCOUNT
  FREE_DELIVERY
  WALLET_CASHBACK
  REWARD_POINT_BONUS
  FIRST_ORDER
  HAPPY_HOUR
  FLASH_SALE
  LOCALITY_BASED
  REFERRAL_CAMPAIGN
}

enum OfferRuleType {
  HAPPY_HOUR
  LOCALITY
  FIRST_ORDER
  WALLET_TIER
  MIN_ORDER
  FLASH_INVENTORY
  REFERRAL
  CATEGORY_AFFINITY
}

enum AudienceType {
  ALL
  NEW_USERS
  WALLET_TIER
  LOCALITY
  CATEGORY_AFFINITY
  SEARCH_HISTORY
}

enum CampaignEventType {
  IMPRESSION
  CLICK
  REDEMPTION
