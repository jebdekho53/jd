enum InventoryTransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum FulfillmentOrderStatus {
  PENDING
  ALLOCATED
  PICKING
  PACKED
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum FulfillmentAuditAction {
  ROUTE_SELECTED
  SPLIT_CREATED
  TRANSFER_REQUESTED
  TRANSFER_APPROVED
  TRANSFER_COMPLETED
  CAPACITY_BLOCKED
  REBALANCE_SUGGESTED
}

model StoreNetwork {
  id                String   @id @default(cuid())
  merchantProfileId String   @map("merchant_profile_id")
  name              String
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  merchantProfile   MerchantProfile   @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  hubs              StoreHub[]
  fulfillmentZones  FulfillmentZone[]
  fulfillmentRules  FulfillmentRule[]
  fulfillmentAudits FulfillmentAudit[]

  @@index([merchantProfileId, isActive])
  @@map("store_networks")
}

model StoreHub {
  id        String    @id @default(cuid())
  networkId String    @map("network_id")
  storeId   String    @map("store_id")
  isHub     Boolean   @default(false) @map("is_hub")
  priority  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  network StoreNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  store   Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([networkId, storeId])
  @@index([storeId])
  @@map("store_hubs")
}

model FulfillmentZone {
  id        String   @id @default(cuid())
  networkId String   @map("network_id")
  name      String
  centerLat Float    @map("center_lat")
  centerLng Float    @map("center_lng")
  radiusKm  Float    @map("radius_km")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  network StoreNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId, isActive])
  @@map("fulfillment_zones")
}

model FulfillmentRule {
  id        String   @id @default(cuid())
  networkId String   @map("network_id")
  ruleType  String   @map("rule_type")
  config    Json     @default("{}")
  priority  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  network StoreNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId, isActive, priority])
  @@map("fulfillment_rules")
}

model InventoryTransfer {
  id                String                  @id @default(cuid())
  merchantProfileId String                  @map("merchant_profile_id")
  fromStoreId       String                  @map("from_store_id")
  toStoreId         String                  @map("to_store_id")
  status            InventoryTransferStatus @default(REQUESTED)
  requestedBy       String                  @map("requested_by")
  approvedBy        String?                 @map("approved_by")
  notes             String?                 @db.Text
  requestedAt       DateTime                @default(now()) @map("requested_at")
  approvedAt        DateTime?               @map("approved_at")
  completedAt       DateTime?               @map("completed_at")
  cancelledAt       DateTime?               @map("cancelled_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  fromStore       Store           @relation("TransferFromStore", fields: [fromStoreId], references: [id], onDelete: Restrict)
  toStore         Store           @relation("TransferToStore", fields: [toStoreId], references: [id], onDelete: Restrict)
  items           TransferItem[]

  @@index([merchantProfileId, status, requestedAt(sort: Desc)])
  @@index([fromStoreId, status])
  @@index([toStoreId, status])
  @@map("inventory_transfers")
}

model TransferItem {
  id         String @id @default(cuid())
  transferId String @map("transfer_id")
  variantId  String @map("variant_id")
  sku        String
  quantity   Int

  transfer InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@map("transfer_items")
}

model StoreCapacitySnapshot {
  id               String   @id @default(cuid())
  storeId          String   @map("store_id")
  ordersPerHour    Int      @default(0) @map("orders_per_hour")
  pickersAvailable Int      @default(0) @map("pickers_available")
  packingStations  Int      @default(0) @map("packing_stations")
  currentLoadPct   Float    @default(0) @map("current_load_pct")
  peakLoadPct      Float    @default(0) @map("peak_load_pct")
  backlogCount     Int      @default(0) @map("backlog_count")
  snapshotAt       DateTime @default(now()) @map("snapshot_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, snapshotAt(sort: Desc)])
  @@map("store_capacity_snapshots")
}

model FulfillmentOrder {
  id                 String                 @id @default(cuid())
  orderId            String                 @map("order_id")
  fulfillmentStoreId String                 @map("fulfillment_store_id")
  status             FulfillmentOrderStatus @default(ALLOCATED)
  etaMins            Int?                   @map("eta_mins")
  routingScore       Float?                 @map("routing_score")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  order            Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fulfillmentStore Store                  @relation(fields: [fulfillmentStoreId], references: [id], onDelete: Restrict)
  items            FulfillmentOrderItem[]

  @@index([orderId])
  @@index([fulfillmentStoreId, status])
  @@map("fulfillment_orders")
}

model FulfillmentOrderItem {
  id                 String @id @default(cuid())
  fulfillmentOrderId String @map("fulfillment_order_id")
  orderItemId        String @map("order_item_id")
  variantId          String @map("variant_id")
  quantity           Int

  fulfillmentOrder FulfillmentOrder @relation(fields: [fulfillmentOrderId], references: [id], onDelete: Cascade)
  orderItem        OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  variant          ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([fulfillmentOrderId])
  @@map("fulfillment_order_items")
}

model FulfillmentAudit {
  id        String                 @id @default(cuid())
  networkId String?                @map("network_id")
  orderId   String?                @map("order_id")
  storeId   String?                @map("store_id")
  action    FulfillmentAuditAction
  metadata  Json?
  createdAt DateTime               @default(now()) @map("created_at")

  network StoreNetwork? @relation(fields: [networkId], references: [id], onDelete: SetNull)
  order   Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  store   Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt(sort: Desc)])
  @@index([networkId, action, createdAt(sort: Desc)])
  @@map("fulfillment_audits")
}

// =============================================================================
// VENDOR MARKETPLACE, PROCUREMENT & B2B SUPPLY CHAIN (P6.3)
// =============================================================================

enum VendorType {
  BRAND
  MANUFACTURER
  WHOLESALER
  DISTRIBUTOR
  IMPORTER
  LOCAL_SUPPLIER
}

enum VendorOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum VendorShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum VendorInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum VendorSettlementStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ProcurementAlertType {
  LOW_STOCK_REPLENISH
  HIGH_DEMAND_ALERT
  SEASONAL_DEMAND_ALERT
  FAST_MOVING_SKU
  OUT_OF_STOCK_RISK
}

enum VendorReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REJECTED
}

enum VendorDisputeStatus {
  OPEN
  RESOLVED
  ESCALATED
}

model VendorProfile {
  id           String     @id @default(cuid())
  userId       String     @unique @map("user_id")
  vendorId     String     @unique @map("vendor_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

model Vendor {
  id            String     @id @default(cuid())
  vendorType    VendorType @map("vendor_type")
  businessName  String     @map("business_name")
  gstNumber     String?    @map("gst_number")
  panNumber     String?    @map("pan_number")
  phone         String?
  email         String?
  cityId        String?    @map("city_id")
  line1         String?
  pincode       String?
  latitude      Float?
  longitude     Float?
  serviceRadiusKm Float    @default(50) @map("service_radius_km")
  isActive      Boolean    @default(true) @map("is_active")
  ratingAvg     Float      @default(0) @map("rating_avg")
  ratingCount   Int        @default(0) @map("rating_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  city         City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  profile      VendorProfile?
  catalogs     VendorCatalog[]
  products     VendorProduct[]
  orders       VendorOrder[]
  settlements  VendorSettlement[]
  creditLines  VendorCreditLine[]
  ratings      VendorRating[]
  procurementCarts ProcurementCart[]

  @@index([vendorType, isActive])
  @@index([cityId, isActive])
  @@map("vendors")
}

model VendorCatalog {
  id          String   @id @default(cuid())
  vendorId    String   @map("vendor_id")
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vendor   Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  products VendorProduct[]

  @@index([vendorId, isActive])
  @@map("vendor_catalogs")
}

model VendorProduct {
  id           String   @id @default(cuid())
  vendorId     String   @map("vendor_id")
  catalogId    String   @map("catalog_id")
  name         String
  sku          String
  description  String?  @db.Text
  category     String?
  hsnCode      String?  @map("hsn_code")
  gstRate      Float    @default(0) @map("gst_rate")
  basePrice    Decimal  @map("base_price") @db.Decimal(10, 2)
  moq          Int      @default(1)
  leadTimeDays Int      @default(3) @map("lead_time_days")
  unit         String   @default("unit")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor       Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  catalog      VendorCatalog         @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  inventory    VendorInventory?
  priceTiers   VendorPriceTier[]
  cartItems    ProcurementCartItem[]
  orderItems   VendorOrderItem[]
  wishlists    ProcurementWishlist[]
  recommendations PurchaseRecommendation[]

  @@unique([vendorId, sku])
  @@index([catalogId, isActive])
  @@map("vendor_products")
}

model VendorInventory {
  id              String @id @default(cuid())
  vendorProductId String @unique @map("vendor_product_id")
  availableQty    Int    @default(0) @map("available_qty")
  reservedQty     Int    @default(0) @map("reserved_qty")
  updatedAt       DateTime @updatedAt @map("updated_at")

  vendorProduct VendorProduct @relation(fields: [vendorProductId], references: [id], onDelete: Cascade)

  @@map("vendor_inventories")
}

model VendorPriceTier {
  id              String  @id @default(cuid())
  vendorProductId String  @map("vendor_product_id")
  minQty          Int     @map("min_qty")
  maxQty          Int?    @map("max_qty")
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)

  vendorProduct VendorProduct @relation(fields: [vendorProductId], references: [id], onDelete: Cascade)

  @@index([vendorProductId, minQty])
  @@map("vendor_price_tiers")
}

model ProcurementCart {
  id                String   @id @default(cuid())
  merchantProfileId String   @map("merchant_profile_id")
  storeId           String?  @map("store_id")
  vendorId          String?  @map("vendor_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  merchantProfile MerchantProfile       @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  vendor          Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  items           ProcurementCartItem[]

  @@index([merchantProfileId])
  @@map("procurement_carts")
}

model ProcurementCartItem {
  id              String  @id @default(cuid())
  cartId          String  @map("cart_id")
  vendorProductId String  @map("vendor_product_id")
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)

  cart          ProcurementCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  vendorProduct VendorProduct   @relation(fields: [vendorProductId], references: [id], onDelete: Restrict)

  @@unique([cartId, vendorProductId])
  @@map("procurement_cart_items")
}

model ProcurementWishlist {
  id                String   @id @default(cuid())
  merchantProfileId String   @map("merchant_profile_id")
  vendorProductId   String   @map("vendor_product_id")
  createdAt         DateTime @default(now()) @map("created_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  vendorProduct   VendorProduct   @relation(fields: [vendorProductId], references: [id], onDelete: Cascade)

  @@unique([merchantProfileId, vendorProductId])
  @@map("procurement_wishlists")
}

model VendorOrder {
  id                String            @id @default(cuid())
  orderNumber       String            @unique @map("order_number")
  merchantProfileId String            @map("merchant_profile_id")
  storeId           String?           @map("store_id")
  vendorId          String            @map("vendor_id")
  status            VendorOrderStatus @default(PENDING)
  subtotal          Decimal           @db.Decimal(10, 2)
  taxAmount         Decimal           @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount       Decimal           @map("total_amount") @db.Decimal(10, 2)
  creditUsed        Decimal           @default(0) @map("credit_used") @db.Decimal(10, 2)
  notes             String?           @db.Text
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items           VendorOrderItem[]
  shipment        VendorShipment?
  invoice         VendorInvoice?
  returns         VendorReturn[]
  disputes        VendorDispute[]

  @@index([merchantProfileId, status])
  @@index([vendorId, status, createdAt(sort: Desc)])
  @@map("vendor_orders")
}

model VendorOrderItem {
  id              String  @id @default(cuid())
  vendorOrderId   String  @map("vendor_order_id")
  vendorProductId String  @map("vendor_product_id")
  sku             String
  productName     String  @map("product_name")
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal @map("total_price") @db.Decimal(10, 2)

  vendorOrder   VendorOrder   @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  vendorProduct VendorProduct @relation(fields: [vendorProductId], references: [id], onDelete: Restrict)

  @@index([vendorOrderId])
  @@map("vendor_order_items")
}

model VendorShipment {
  id             String               @id @default(cuid())
  vendorOrderId  String               @unique @map("vendor_order_id")
  status         VendorShipmentStatus @default(PENDING)
  carrier        String?
  trackingNumber String?              @map("tracking_number")
  shippedAt      DateTime?            @map("shipped_at")
  deliveredAt    DateTime?            @map("delivered_at")
  createdAt      DateTime             @default(now()) @map("created_at")

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@map("vendor_shipments")
}

model VendorInvoice {
  id            String              @id @default(cuid())
  vendorOrderId String              @unique @map("vendor_order_id")
  invoiceNumber String              @unique @map("invoice_number")
  status        VendorInvoiceStatus @default(DRAFT)
  subtotal      Decimal             @db.Decimal(10, 2)
  taxAmount     Decimal             @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal             @map("total_amount") @db.Decimal(10, 2)
  dueDate       DateTime?           @map("due_date")
  paidAt        DateTime?           @map("paid_at")
  createdAt     DateTime            @default(now()) @map("created_at")

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@map("vendor_invoices")
}

model VendorSettlement {
  id          String                 @id @default(cuid())
  vendorId    String                 @map("vendor_id")
  periodStart DateTime               @map("period_start") @db.Date
  periodEnd   DateTime               @map("period_end") @db.Date
  amount      Decimal                @db.Decimal(10, 2)
  status      VendorSettlementStatus @default(PENDING)
  paidAt      DateTime?              @map("paid_at")
  createdAt   DateTime               @default(now()) @map("created_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, status])
  @@map("vendor_settlements")
}

model VendorCreditLine {
  id                String   @id @default(cuid())
  vendorId          String   @map("vendor_id")
  merchantProfileId String   @map("merchant_profile_id")
  creditLimit       Decimal  @map("credit_limit") @db.Decimal(12, 2)
  usedLimit         Decimal  @default(0) @map("used_limit") @db.Decimal(12, 2)
  dueDate           DateTime? @map("due_date")
  overdueAmount     Decimal  @default(0) @map("overdue_amount") @db.Decimal(12, 2)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)

  @@unique([vendorId, merchantProfileId])
  @@index([merchantProfileId, isActive])
  @@map("vendor_credit_lines")
}

model PurchaseRecommendation {
  id                    String               @id @default(cuid())
  merchantProfileId     String               @map("merchant_profile_id")
  storeId               String?              @map("store_id")
  vendorProductId       String?              @map("vendor_product_id")
  sku                   String
  productName           String               @map("product_name")
  currentStock          Int                  @map("current_stock")
  avgDailySales         Float                @map("avg_daily_sales")
  predictedOosDays      Float                @map("predicted_oos_days")
  recommendedQty        Int                  @map("recommended_qty")
  suggestedVendorId     String?              @map("suggested_vendor_id")
  expectedRevenueImpact Decimal              @map("expected_revenue_impact") @db.Decimal(12, 2)
  alertType             ProcurementAlertType @map("alert_type")
  isDismissed           Boolean              @default(false) @map("is_dismissed")
  createdAt             DateTime             @default(now()) @map("created_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  vendorProduct   VendorProduct?  @relation(fields: [vendorProductId], references: [id], onDelete: SetNull)

  @@index([merchantProfileId, isDismissed, createdAt(sort: Desc)])
  @@index([alertType, createdAt(sort: Desc)])
  @@map("purchase_recommendations")
}

model VendorRating {
  id                String   @id @default(cuid())
  vendorId          String   @map("vendor_id")
  merchantProfileId String   @map("merchant_profile_id")
  rating            Int
  review            String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)

  @@unique([vendorId, merchantProfileId])
  @@map("vendor_ratings")
}

model VendorReturn {
  id            String             @id @default(cuid())
  vendorOrderId String             @map("vendor_order_id")
  status        VendorReturnStatus @default(REQUESTED)
  reason        String             @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  resolvedAt    DateTime?          @map("resolved_at")

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId, status])
  @@map("vendor_returns")
}

model VendorDispute {
  id            String              @id @default(cuid())
  vendorOrderId String              @map("vendor_order_id")
  status        VendorDisputeStatus @default(OPEN)
  reason        String              @db.Text
  resolution    String?             @db.Text
  createdAt     DateTime            @default(now()) @map("created_at")
  resolvedAt    DateTime?           @map("resolved_at")

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)

  @@index([vendorOrderId, status])
  @@map("vendor_disputes")
}

// =============================================================================
// FRANCHISE NETWORK, CITY EXPANSION & TERRITORY GOVERNANCE (P6.4)
// =============================================================================

enum FranchisePartnerStatus {
  ACTIVE
  PENDING
  SUSPENDED
  TERMINATED
}

enum CityLaunchStatus {
  RESEARCH
  PLANNING
  RECRUITING
  SOFT_LAUNCH
  LIVE
}

enum ExpansionLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

enum TerritoryConflictStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum FranchiseSettlementStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum FranchiseAuditAction {
  ONBOARDED
  APPROVED
  SUSPENDED
  TERMINATED
  TERRITORY_ASSIGNED
  CONFLICT_DETECTED
  SETTLEMENT_CREATED
  CITY_LAUNCH_UPDATED
}

model FranchisePartner {
  id                  String                 @id @default(cuid())
  userId              String                 @unique @map("user_id")
  businessName        String                 @map("business_name")
  gstin               String?
  pan                 String?
  status              FranchisePartnerStatus @default(PENDING)
  commissionPercent   Float                  @default(5) @map("commission_percent")
  onboardingCompleted Boolean                @default(false) @map("onboarding_completed")
  cityId              String?                @map("city_id")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  city         City?                @relation(fields: [cityId], references: [id], onDelete: SetNull)
  territories  FranchiseTerritory[]
  stores       FranchiseStore[]
  audits       FranchiseAudit[]
  settlements  FranchiseSettlement[]
  conflicts    TerritoryConflict[]

  @@index([status, createdAt(sort: Desc)])
  @@index([cityId, status])
  @@map("franchise_partners")
}

model FranchiseTerritory {
  id                 String    @id @default(cuid())
  franchiseId        String    @map("franchise_id")
  city               String
  state              String
  country            String    @default("IN")
  pincodes           String[]
  exclusivityEnabled Boolean   @default(false) @map("exclusivity_enabled")
  launchDate         DateTime? @map("launch_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  franchise          FranchisePartner    @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  conflictsAsPrimary TerritoryConflict[] @relation("ConflictPrimary")
  conflictsAsOther   TerritoryConflict[] @relation("ConflictOther")

  @@index([franchiseId])
  @@index([city, state])
  @@map("franchise_territories")
}

model FranchiseStore {
  id          String   @id @default(cuid())
  franchiseId String   @map("franchise_id")
  storeId     String   @map("store_id")
  linkedAt    DateTime @default(now()) @map("linked_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, storeId])
  @@index([storeId])
  @@map("franchise_stores")
}

model CityLaunchPlan {
  id            String           @id @default(cuid())
  cityId        String?          @map("city_id")
  city          String
  state         String
  launchStatus  CityLaunchStatus @default(RESEARCH) @map("launch_status")
  readinessScore Float           @default(0) @map("readiness_score")
  targetStores  Int              @default(0) @map("target_stores")
  targetRiders  Int              @default(0) @map("target_riders")
  targetGmv     Decimal          @default(0) @map("target_gmv") @db.Decimal(14, 2)
  actualStores  Int              @default(0) @map("actual_stores")
  actualRiders  Int              @default(0) @map("actual_riders")
  actualGmv     Decimal          @default(0) @map("actual_gmv") @db.Decimal(14, 2)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  cityRef City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@unique([city, state])
  @@index([launchStatus])
  @@map("city_launch_plans")
}

model ExpansionLead {
  id        String              @id @default(cuid())
  name      String
  phone     String
  email     String?
  city      String
  state     String
  status    ExpansionLeadStatus @default(NEW)
  notes     String?             @db.Text
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@index([city, state])
  @@map("expansion_leads")
}

model TerritoryConflict {
  id                    String                  @id @default(cuid())
  franchiseId           String                  @map("franchise_id")
  primaryTerritoryId    String                  @map("primary_territory_id")
  conflictingTerritoryId String                 @map("conflicting_territory_id")
  pincode               String
  status                TerritoryConflictStatus @default(OPEN)
  resolution            String?                 @db.Text
  createdAt             DateTime                @default(now()) @map("created_at")
  resolvedAt            DateTime?               @map("resolved_at")

  franchise            FranchisePartner   @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  primaryTerritory     FranchiseTerritory @relation("ConflictPrimary", fields: [primaryTerritoryId], references: [id], onDelete: Cascade)
  conflictingTerritory FranchiseTerritory @relation("ConflictOther", fields: [conflictingTerritoryId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([franchiseId])
  @@map("territory_conflicts")
}

model FranchiseAudit {
  id          String               @id @default(cuid())
  franchiseId String               @map("franchise_id")
  action      FranchiseAuditAction
  metadata    Json?
  actorId     String?              @map("actor_id")
  createdAt   DateTime             @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, createdAt(sort: Desc)])
  @@map("franchise_audits")
}

model FranchiseSettlement {
  id              String                    @id @default(cuid())
  franchiseId     String                    @map("franchise_id")
  periodStart     DateTime                  @map("period_start") @db.Date
  periodEnd       DateTime                  @map("period_end") @db.Date
  grossGmv        Decimal                   @default(0) @map("gross_gmv") @db.Decimal(14, 2)
  franchiseShare  Decimal                   @map("franchise_share") @db.Decimal(12, 2)
  platformShare   Decimal                   @default(0) @map("platform_share") @db.Decimal(12, 2)
  status          FranchiseSettlementStatus @default(PENDING)
  ledgerJournalId String?                   @map("ledger_journal_id")
  paidAt          DateTime?                 @map("paid_at")
  createdAt       DateTime                  @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, status])
  @@index([periodStart, periodEnd])
  @@map("franchise_settlements")
}

// =============================================================================
// P7.1 — AI COMMERCE INTELLIGENCE
// =============================================================================

enum AIRecommendationEntityType {
  STORE
  PRODUCT
  MERCHANT
  CAMPAIGN
}

enum AIRecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PricingRecommendationStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

enum InventoryForecastUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model DemandForecast {
  id               String   @id @default(cuid())
  storeId          String   @map("store_id")
  productId        String   @map("product_id")
  forecastDate     DateTime @map("forecast_date") @db.Date
  predictedDemand  Int      @map("predicted_demand")
  confidenceScore  Float    @map("confidence_score")
  actualDemand     Int?     @map("actual_demand")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, forecastDate])
  @@index([forecastDate])
  @@map("demand_forecasts")
}

model InventoryForecast {
  id              String                   @id @default(cuid())
  storeId         String                   @map("store_id")
  productId       String                   @map("product_id")
  daysUntilStockout Int                    @map("days_until_stockout")
  recommendedQty  Int                      @map("recommended_qty")
  urgency         InventoryForecastUrgency @default(MEDIUM)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@index([urgency])
  @@map("inventory_forecasts")
}

model PricingRecommendation {
  id                  String                      @id @default(cuid())
  storeId             String                      @map("store_id")
  productId           String                      @map("product_id")
  currentPrice        Decimal                     @map("current_price") @db.Decimal(10, 2)
  recommendedPrice    Decimal                     @map("recommended_price") @db.Decimal(10, 2)
  expectedLiftPercent Float                       @map("expected_lift_percent")
  status              PricingRecommendationStatus @default(PENDING)
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@map("pricing_recommendations")
}

model DemandHotspot {
  id          String   @id @default(cuid())
  city        String
  locality    String
  categoryId  String?  @map("category_id")
  demandScore Float    @map("demand_score")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([city, locality, categoryId])
  @@index([demandScore(sort: Desc)])
  @@map("demand_hotspots")
}

model AIRecommendation {
  id          String                     @id @default(cuid())
  entityType  AIRecommendationEntityType @map("entity_type")
  entityId    String                     @map("entity_id")
  title       String
  description String
  priority    AIRecommendationPriority   @default(MEDIUM)
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([priority, createdAt(sort: Desc)])
  @@map("ai_recommendations")
}

// =============================================================================
// P7.2 — REAL-TIME FLEET OS
// =============================================================================

enum DeliveryBatchStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum FleetAlertType {
  LOW_RIDER_SUPPLY
  ORDER_SURGE
  SLOW_DELIVERIES
  CLUSTER_IMBALANCE
}

enum FleetAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model RiderCluster {
  id                 String   @id @default(cuid())
  city               String
  locality           String
  activeRiders       Int      @default(0) @map("active_riders")
  activeOrders       Int      @default(0) @map("active_orders")
  demandSupplyRatio  Float    @default(0) @map("demand_supply_ratio")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([city, locality])
  @@index([demandSupplyRatio(sort: Desc)])
  @@map("rider_clusters")
}

model DeliveryBatch {
  id           String              @id @default(cuid())
  riderId      String              @map("rider_id")
  status       DeliveryBatchStatus @default(PLANNED)
  totalOrders  Int                 @default(0) @map("total_orders")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  completedAt  DateTime?           @map("completed_at")

  rider            RiderProfile         @relation(fields: [riderId], references: [id], onDelete: Cascade)
  items            DeliveryBatchItem[]
  routeOptimizations RouteOptimization[]

  @@index([riderId, status])
  @@map("delivery_batches")
}

model DeliveryBatchItem {
  id       String @id @default(cuid())
  batchId  String @map("batch_id")
  orderId  String @map("order_id")
  sequence Int    @default(1)

  batch DeliveryBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([batchId, orderId])
  @@unique([orderId])
  @@index([batchId, sequence])
  @@map("delivery_batch_items")
}

model FleetAlert {
  id             String           @id @default(cuid())
  alertType      FleetAlertType   @map("alert_type")
  status         FleetAlertStatus @default(OPEN)
  city           String?
  locality       String?
  riderProfileId String?          @map("rider_profile_id")
  message        String
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  resolvedAt     DateTime?        @map("resolved_at")

  riderProfile RiderProfile? @relation(fields: [riderProfileId], references: [id], onDelete: SetNull)

  @@index([alertType, status])
  @@index([createdAt(sort: Desc)])
  @@map("fleet_alerts")
}

model RouteOptimization {
  id                String   @id @default(cuid())
  riderId           String   @map("rider_id")
  batchId           String?  @map("batch_id")
  distanceKm        Float    @map("distance_km")
  estimatedMinutes  Int      @map("estimated_minutes")
  optimized         Boolean  @default(false)
  routeSequence     Json?    @map("route_sequence")
  createdAt         DateTime @default(now()) @map("created_at")

  rider RiderProfile   @relation(fields: [riderId], references: [id], onDelete: Cascade)
  batch DeliveryBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([riderId, createdAt(sort: Desc)])
  @@map("route_optimizations")
}

// =============================================================================
// P7.3 — RETAIL MEDIA & ADVERTISING
// =============================================================================

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum AdPlacement {
  SEARCH
  HOME
  CATEGORY
}

model AdCampaign {
  id           String           @id @default(cuid())
  name         String
  advertiserId String           @map("advertiser_id")
  status       AdCampaignStatus @default(DRAFT)
  budget       Decimal          @db.Decimal(14, 2)
  spentAmount  Decimal          @default(0) @map("spent_amount") @db.Decimal(14, 2)
  startAt      DateTime?        @map("start_at")
  endAt        DateTime?        @map("end_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  advertiser       MerchantProfile   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adGroups         AdGroup[]
  sponsoredProducts SponsoredProduct[]
  sponsoredStores  SponsoredStore[]
  keywordBids      KeywordBid[]
  impressions      AdImpression[]
  clicks           AdClick[]
  conversions      AdConversion[]

  @@index([advertiserId, status])
  @@index([status, startAt])
  @@map("ad_campaigns")
}

model AdGroup {
  id          String  @id @default(cuid())
  campaignId  String  @map("campaign_id")
  bidAmount   Decimal @map("bid_amount") @db.Decimal(10, 2)
  dailyBudget Decimal @map("daily_budget") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("ad_groups")
}

model SponsoredProduct {
  id         String @id @default(cuid())
  campaignId String @map("campaign_id")
  productId  String @map("product_id")
  priority   Int    @default(0)

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
  @@index([productId, priority(sort: Desc)])
  @@map("sponsored_products")
}

model SponsoredStore {
  id         String @id @default(cuid())
  campaignId String @map("campaign_id")
  storeId    String @map("store_id")
  priority   Int    @default(0)

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  store    Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, storeId])
  @@index([storeId, priority(sort: Desc)])
  @@map("sponsored_stores")
}

model KeywordBid {
  id         String  @id @default(cuid())
  keyword    String
  bidAmount  Decimal @map("bid_amount") @db.Decimal(10, 2)
  campaignId String  @map("campaign_id")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, keyword])
  @@index([keyword])
  @@map("keyword_bids")
}

model AdImpression {
  id         String      @id @default(cuid())
  campaignId String      @map("campaign_id")
  userId     String?     @map("user_id")
  placement  AdPlacement
  cost       Decimal     @default(0) @db.Decimal(10, 4)
  createdAt  DateTime    @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt(sort: Desc)])
  @@index([placement, createdAt(sort: Desc)])
  @@map("ad_impressions")
}

model AdClick {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  userId     String?  @map("user_id")
  cost       Decimal  @default(0) @db.Decimal(10, 4)
  createdAt  DateTime @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt(sort: Desc)])
  @@map("ad_clicks")
}

model AdConversion {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  orderId    String   @map("order_id")
  revenue    Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order    Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, campaignId])
  @@index([campaignId, createdAt(sort: Desc)])
  @@map("ad_conversions")
}

// =============================================================================
// P7.4 — JEBDEKHO PLUS MEMBERSHIP
// =============================================================================

enum MembershipBenefitType {
  FREE_DELIVERY
  PRIORITY_DELIVERY
  EXTRA_REWARDS
  VIP_SUPPORT
  EXCLUSIVE_OFFERS
}

enum MembershipSubscriptionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

model MembershipPlan {
  id           String   @id @default(cuid())
  name         String
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(10, 2)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  benefits      MembershipBenefit[]
  subscriptions MembershipSubscription[]

  @@map("membership_plans")
}

model MembershipBenefit {
  id     String                @id @default(cuid())
  planId String                @map("plan_id")
  type   MembershipBenefitType

  plan MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, type])
  @@map("membership_benefits")
}

model MembershipSubscription {
  id        String                       @id @default(cuid())
  userId    String                       @map("user_id")
  buyerProfileId String?                 @map("buyer_profile_id")
  planId    String                       @map("plan_id")
  status    MembershipSubscriptionStatus @default(ACTIVE)
  startedAt DateTime                     @map("started_at")
  expiresAt DateTime                     @map("expires_at")
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyerProfile BuyerProfile?    @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)
  plan         MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  usages       MembershipUsage[]

  @@index([userId, status])
  @@index([expiresAt])
  @@map("membership_subscriptions")
}

model MembershipUsage {
  id             String                @id @default(cuid())
  subscriptionId String                @map("subscription_id")
  benefitType    MembershipBenefitType @map("benefit_type")
  orderId        String?               @map("order_id")
  createdAt      DateTime              @default(now()) @map("created_at")

  subscription MembershipSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  order        Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, createdAt(sort: Desc)])
  @@map("membership_usages")
}

// =============================================================================
// P7.5 — CORPORATE & INSTITUTIONAL COMMERCE
// =============================================================================

enum CorporateAccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum CorporateUserRole {
  ADMIN
  APPROVER
  EMPLOYEE
}

enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CorporateAccount {
  id          String                 @id @default(cuid())
  companyName String                 @map("company_name")
  gstin       String?
  creditLimit Decimal                @default(0) @map("credit_limit") @db.Decimal(14, 2)
  status      CorporateAccountStatus @default(PENDING)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  users            CorporateUser[]
  wallet           CorporateWallet?
  costCenters      CostCenter[]
  approvalWorkflows ApprovalWorkflow[]
  invoices         CorporateInvoice[]

  @@index([status])
  @@map("corporate_accounts")
}

model CorporateUser {
  id        String            @id @default(cuid())
  accountId String            @map("account_id")
  userId    String            @map("user_id")
  role      CorporateUserRole @default(EMPLOYEE)
  createdAt DateTime          @default(now()) @map("created_at")

  account          CorporateAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseRequests PurchaseRequest[]

  @@unique([accountId, userId])
  @@index([userId])
  @@map("corporate_users")
}

model CorporateWallet {
  id        String   @id @default(cuid())
  accountId String   @unique @map("account_id")
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  account CorporateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("corporate_wallets")
}

model CostCenter {
  id           String  @id @default(cuid())
  accountId    String  @map("account_id")
  name         String
  monthlyLimit Decimal @default(0) @map("monthly_limit") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  account CorporateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("cost_centers")
}

model PurchaseRequest {
  id         String                @id @default(cuid())
  employeeId String                @map("employee_id")
  orderId    String?               @unique @map("order_id")
  amount     Decimal               @default(0) @db.Decimal(12, 2)
  status     PurchaseRequestStatus @default(PENDING)
  notes      String?
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  employee CorporateUser @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  order    Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@map("purchase_requests")
}

model ApprovalWorkflow {
  id             String  @id @default(cuid())
  accountId      String  @map("account_id")
  approvalLimit  Decimal @map("approval_limit") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  account CorporateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("approval_workflows")
}

model CorporateInvoice {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  invoiceNumber String   @unique @map("invoice_number")
  invoiceAmount Decimal  @map("invoice_amount") @db.Decimal(14, 2)
  periodStart   DateTime? @map("period_start") @db.Date
  periodEnd     DateTime? @map("period_end") @db.Date
  ledgerJournalId String? @map("ledger_journal_id")
  createdAt     DateTime @default(now()) @map("created_at")

  account CorporateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@map("corporate_invoices")
}

// ---------------------------------------------------------------------------
// P7.6 — SEO, AEO & GEO Growth Engine
// ---------------------------------------------------------------------------

enum SeoPageType {
  CITY
  CITY_CATEGORY
  STORE
  CATEGORY
  BRAND
  FAQ
  STATIC
}

enum SeoEntityType {
  PLATFORM
  PLUS
  STORE
  CATEGORY
  CITY
  MERCHANT
  BRAND
}

enum GeoMentionEngine {
  CHATGPT
  OPENAI
  GEMINI
  GOOGLE_AI_OVERVIEW
  PERPLEXITY
  CLAUDE
  COPILOT
  BING_AI
  OTHER
}

enum SitemapType {
  INDEX
  PRODUCTS
  STORES
  CATEGORIES
  CITIES
  FAQ
}

enum AiCrawlerType {
  CHATGPT
  OPENAI
  GEMINI
  GOOGLE_AI
  PERPLEXITY
  CLAUDE
  BING_AI
  OTHER
}

model SeoPage {
  id           String      @id @default(cuid())
  slug         String      @unique
  path         String      @unique
  pageType     SeoPageType @map("page_type")
  title        String
  description  String?     @db.Text
  h1           String?
  canonicalUrl String?     @map("canonical_url")
  entityType   String?     @map("entity_type")
  entityId     String?     @map("entity_id")
  cityId       String?     @map("city_id")
  categoryId   String?     @map("category_id")
  storeId      String?     @map("store_id")
  brandSlug    String?     @map("brand_slug")
  metaJson     Json?       @map("meta_json")
  indexable    Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  city     City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  faqs     SeoFaq[]
  keywords SeoKeyword[]

  @@index([pageType, indexable])
  @@index([cityId])
  @@index([storeId])
  @@map("seo_pages")
}

model SeoFaq {
  id          String   @id @default(cuid())
  pageId      String?  @map("page_id")
  question    String   @db.Text
  answer      String   @db.Text
  slug        String   @unique
  category    String?
  cityId      String?  @map("city_id")
  featured    Boolean  @default(false)
  aeoScore    Float    @default(0) @map("aeo_score")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  page SeoPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  city City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@index([featured, aeoScore(sort: Desc)])
  @@map("seo_faqs")
}

model SeoKeyword {
  id          String   @id @default(cuid())
  keyword     String
  pageId      String?  @map("page_id")
  storeId     String?  @map("store_id")
  avgPosition Float?   @map("avg_position")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  trackedAt   DateTime @default(now()) @map("tracked_at")
  createdAt   DateTime @default(now()) @map("created_at")

  page  SeoPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  store Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([keyword])
  @@index([storeId])
  @@map("seo_keywords")
}

model SeoEntity {
  id             String        @id @default(cuid())
  entityType     SeoEntityType @map("entity_type")
  entityId       String?       @map("entity_id")
  name           String
  slug           String
  description    String?       @db.Text
  relations      Json          @default("[]")
  knowledgeJson  Json?         @map("knowledge_json")
  coverageScore  Float         @default(0) @map("coverage_score")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([entityType, slug])
  @@index([entityType, coverageScore(sort: Desc)])
  @@map("seo_entities")
}

model SeoSnapshot {
  id                  String   @id @default(cuid())
  snapshotDate        DateTime @map("snapshot_date") @db.Date
  organicTraffic      Int      @default(0) @map("organic_traffic")
  keywordRankings     Json     @default("{}") @map("keyword_rankings")
  ctr                 Float    @default(0)
  aiCitations         Int      @default(0) @map("ai_citations")
  featuredSnippetWins Int      @default(0) @map("featured_snippet_wins")
  geoVisibilityScore  Float    @default(0) @map("geo_visibility_score")
  aeoVisibilityScore  Float    @default(0) @map("aeo_visibility_score")
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([snapshotDate])
  @@map("seo_snapshots")
}

model GeoMention {
  id          String           @id @default(cuid())
  engine      GeoMentionEngine
  query       String           @db.Text
  citedUrl    String?          @map("cited_url")
  entityType  String?          @map("entity_type")
  entityId    String?          @map("entity_id")
  sentiment   String?
  mentionText String?          @map("mention_text") @db.Text
  detectedAt  DateTime         @default(now()) @map("detected_at")

  @@index([engine, detectedAt(sort: Desc)])
  @@map("geo_mentions")
}

model SitemapIndex {
  id               String      @id @default(cuid())
  sitemapType      SitemapType @unique @map("sitemap_type")
  url              String
  lastGeneratedAt  DateTime    @map("last_generated_at")
  urlCount         Int         @default(0) @map("url_count")
  xmlContent       String?     @map("xml_content") @db.Text
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

