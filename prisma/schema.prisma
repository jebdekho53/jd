model LedgerAccount {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  kind      LedgerAccountKind
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")

  entries LedgerEntry[]

  @@map("ledger_accounts")
}

model LedgerJournal {
  id             String              @id @default(cuid())
  referenceType  LedgerReferenceType @map("reference_type")
  referenceId    String              @map("reference_id")
  orderId        String?             @map("order_id")
  description    String
  idempotencyKey String              @unique @map("idempotency_key")
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")

  entries LedgerEntry[]
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([referenceType, referenceId])
  @@index([orderId])
  @@index([createdAt(sort: Desc)])
  @@map("ledger_journals")
}

model LedgerEntry {
  id        String   @id @default(cuid())
  journalId String   @map("journal_id")
  accountId String   @map("account_id")
  debit     Decimal  @default(0) @db.Decimal(14, 2)
  credit    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @map("created_at")

  journal LedgerJournal @relation(fields: [journalId], references: [id], onDelete: Restrict)
  account LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalId])
  @@index([accountId])
  @@map("ledger_entries")
}

model CommissionRule {
  id                  String              @id @default(cuid())
  scope               CommissionRuleScope
  storeId             String?             @map("store_id")
  categoryId          String?             @map("category_id")
  campaignId          String?             @map("campaign_id")
  commissionPercent   Decimal             @map("commission_percent") @db.Decimal(5, 2)
  settlementDelayDays Int                 @default(2) @map("settlement_delay_days")
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  store    Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([scope, isActive])
  @@index([storeId])
  @@index([categoryId])
  @@index([campaignId])
  @@map("commission_rules")
}

model OrderFinancialSnapshot {
  id                    String   @id @default(cuid())
  orderId               String   @unique @map("order_id")
  subtotal              Decimal  @db.Decimal(12, 2)
  discountAmount        Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  offerSubsidy          Decimal  @default(0) @map("offer_subsidy") @db.Decimal(12, 2)
  merchantContribution  Decimal  @default(0) @map("merchant_contribution") @db.Decimal(12, 2)
  platformContribution  Decimal  @default(0) @map("platform_contribution") @db.Decimal(12, 2)
  deliveryFee           Decimal  @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  taxAmount             Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  commissionPercent     Decimal  @map("commission_percent") @db.Decimal(5, 2)
  commissionAmount      Decimal  @map("commission_amount") @db.Decimal(12, 2)
  netMerchantEarnings   Decimal  @map("net_merchant_earnings") @db.Decimal(12, 2)
  netPlatformEarnings   Decimal  @map("net_platform_earnings") @db.Decimal(12, 2)
  riderPayoutAmount     Decimal  @default(0) @map("rider_payout_amount") @db.Decimal(12, 2)
  commissionRuleId      String?  @map("commission_rule_id")
  storeSnapshot         Json     @map("store_snapshot")
  frozenAt              DateTime @default(now()) @map("frozen_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_financial_snapshots")
}

model Settlement {
  id                String                @id @default(cuid())
  merchantProfileId String                @map("merchant_profile_id")
  cycle             SettlementCycle
  status            SettlementBatchStatus @default(PENDING)
  periodStart       DateTime              @map("period_start")
  periodEnd         DateTime              @map("period_end")
  grossAmount       Decimal               @default(0) @map("gross_amount") @db.Decimal(14, 2)
  commissionAmount  Decimal               @default(0) @map("commission_amount") @db.Decimal(14, 2)
  refundAdjustments Decimal               @default(0) @map("refund_adjustments") @db.Decimal(14, 2)
  walletAdjustments Decimal               @default(0) @map("wallet_adjustments") @db.Decimal(14, 2)
  netAmount         Decimal               @default(0) @map("net_amount") @db.Decimal(14, 2)
  itemCount         Int                   @default(0) @map("item_count")
  processedAt       DateTime?             @map("processed_at")
  failureReason     String?               @map("failure_reason") @db.Text
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  merchantProfile MerchantProfile  @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  items           SettlementItem[]
  merchantPayouts MerchantPayout[]

  @@index([merchantProfileId, status])
  @@index([periodStart, periodEnd])
  @@map("settlements")
}

model SettlementItem {
  id                 String   @id @default(cuid())
  settlementId       String   @map("settlement_id")
  orderId            String   @map("order_id")
  settlementLedgerId String?  @map("settlement_ledger_id")
  grossAmount        Decimal  @map("gross_amount") @db.Decimal(12, 2)
  commissionAmount   Decimal  @map("commission_amount") @db.Decimal(12, 2)
  netAmount          Decimal  @map("net_amount") @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @map("created_at")

  settlement       Settlement        @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  settlementLedger SettlementLedger? @relation(fields: [settlementLedgerId], references: [id], onDelete: SetNull)

  @@unique([settlementId, orderId])
  @@index([settlementId])
  @@map("settlement_items")
}

model MerchantPayout {
  id                String                     @id @default(cuid())
  merchantProfileId String                     @map("merchant_profile_id")
  settlementId      String?                    @map("settlement_id")
  payoutRequestId   String?                    @unique @map("payout_request_id")
  amount            Decimal                    @db.Decimal(12, 2)
  status            MerchantPayoutRecordStatus @default(PENDING)
  referenceId       String?                    @map("reference_id")
  bankSnapshot      Json?                      @map("bank_snapshot")
  processedAt       DateTime?                  @map("processed_at")
  processedBy       String?                    @map("processed_by")
  createdAt         DateTime                   @default(now()) @map("created_at")

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  settlement      Settlement?     @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  payoutRequest   PayoutRequest?  @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)

  @@index([merchantProfileId, status])
  @@map("merchant_payouts")
}

model RiderPayout {
  id             String            @id @default(cuid())
  riderProfileId String            @map("rider_profile_id")
  status         RiderPayoutStatus @default(PENDING)
  periodStart    DateTime          @map("period_start")
  periodEnd      DateTime          @map("period_end")
  baseFee        Decimal           @default(0) @map("base_fee") @db.Decimal(12, 2)
  distanceBonus  Decimal           @default(0) @map("distance_bonus") @db.Decimal(12, 2)
  peakBonus      Decimal           @default(0) @map("peak_bonus") @db.Decimal(12, 2)
  rainBonus      Decimal           @default(0) @map("rain_bonus") @db.Decimal(12, 2)
  incentives     Decimal           @default(0) @db.Decimal(12, 2)
  cancellationComp Decimal         @default(0) @map("cancellation_comp") @db.Decimal(12, 2)
  totalAmount    Decimal           @map("total_amount") @db.Decimal(12, 2)
  referenceId    String?           @map("reference_id")
  paidAt         DateTime?         @map("paid_at")
  createdAt      DateTime          @default(now()) @map("created_at")

  riderProfile RiderProfile      @relation(fields: [riderProfileId], references: [id], onDelete: Restrict)
  items        RiderPayoutItem[]

  @@index([riderProfileId, status])
  @@map("rider_payouts")
}

model RiderPayoutItem {
  id            String   @id @default(cuid())
  riderPayoutId String   @map("rider_payout_id")
  deliveryId    String   @map("delivery_id")
  orderId       String   @map("order_id")
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  riderPayout RiderPayout @relation(fields: [riderPayoutId], references: [id], onDelete: Cascade)
  delivery    Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Restrict)

  @@unique([riderPayoutId, deliveryId])
  @@map("rider_payout_items")
}

model TaxRecord {
  id                String   @id @default(cuid())
  orderId           String?  @map("order_id")
  settlementId      String?  @map("settlement_id")
  merchantProfileId String?  @map("merchant_profile_id")
  taxType           String   @map("tax_type")
  taxableAmount     Decimal  @map("taxable_amount") @db.Decimal(12, 2)
  taxAmount         Decimal  @map("tax_amount") @db.Decimal(12, 2)
  gstRate           Decimal? @map("gst_rate") @db.Decimal(5, 2)
  periodMonth       String?  @map("period_month")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([periodMonth])
  @@index([merchantProfileId])
  @@index([orderId])
  @@map("tax_records")
}

model CodReconciliation {
  id               String                   @id @default(cuid())
  riderProfileId   String?                  @map("rider_profile_id")
  providerType     DeliveryProviderType?    @map("provider_type")
  orderId          String?                  @map("order_id")
  amountExpected   Decimal                  @map("amount_expected") @db.Decimal(12, 2)
  amountCollected  Decimal                  @default(0) @map("amount_collected") @db.Decimal(12, 2)
  amountDeposited  Decimal                  @default(0) @map("amount_deposited") @db.Decimal(12, 2)
  mismatchAmount   Decimal                  @default(0) @map("mismatch_amount") @db.Decimal(12, 2)
  status           CodReconciliationStatus  @default(PENDING)
  submittedAt      DateTime?                @map("submitted_at")
  verifiedAt       DateTime?                @map("verified_at")
  verifiedBy       String?                  @map("verified_by")
  rejectionReason  String?                  @map("rejection_reason") @db.Text
  notes            String?                  @db.Text
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  riderProfile RiderProfile? @relation(fields: [riderProfileId], references: [id], onDelete: Restrict)
  order        Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([riderProfileId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("cod_reconciliations")
}

model FinanceAlert {
  id         String               @id @default(cuid())
  alertType  FinanceAlertType     @map("alert_type")
  severity   FinanceAlertSeverity
  status     FinanceAlertStatus   @default(OPEN)
  title      String
  message    String               @db.Text
  metadata   Json?
  resolvedAt DateTime?            @map("resolved_at")
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([status, severity])
  @@index([alertType, createdAt(sort: Desc)])
  @@map("finance_alerts")
