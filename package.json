{
  "name": "jebdekho",
  "version": "0.1.0",
  "private": true,
  "description": "Hyperlocal multi-vendor commerce platform",
  "scripts": {
    "dev": "pnpm dev:infra && turbo run dev --filter=./apps/*",
    "dev:apps": "turbo run dev --filter=./apps/*",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "dev:api": "pnpm --filter @jebdekho/api run start:dev",
    "dev:buyer-web": "pnpm --filter @jebdekho/buyer-web run dev",
    "build": "pnpm exec turbo run build",
    "build:prod": "bash deploy/scripts/build-production.sh",
    "lint": "pnpm exec turbo run lint",
    "test": "pnpm exec turbo run test",
    "install:deploy": "pnpm install --frozen-lockfile --prod=false",
    "db:generate": "pnpm exec prisma generate --schema=prisma/schema.prisma",
    "postinstall": "pnpm exec prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:dev": "pnpm exec prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:prod": "pnpm exec prisma migrate deploy --schema=prisma/schema.prisma",
    "db:deploy": "pnpm exec prisma migrate deploy --schema=prisma/schema.prisma",
    "db:setup:prod": "pnpm db:generate && pnpm db:migrate:prod && pnpm db:seed:locations",
    "db:seed:platform": "pnpm exec tsx prisma/seed-platform.ts",
    "seed:menu-catalog": "pnpm exec tsx prisma/seed-menu-catalog.ts",
    "db:execute-category-soft-delete": "pnpm exec prisma db execute --schema=prisma/schema.prisma --file prisma/migrations/20260626120000_category_soft_delete/migration.sql",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "db:seed:locations": "pnpm exec tsx prisma/seed-location-directory.ts",
    "db:studio": "pnpm exec prisma studio --schema=prisma/schema.prisma",
    "db:reset": "pnpm exec prisma migrate reset --schema=prisma/schema.prisma",
    "deploy:production": "bash deploy/deploy.sh",
    "deploy:rollback": "bash deploy/rollback.sh",
    "vps:update": "bash deploy/scripts/vps-update.sh",
    "preflight": "tsx scripts/production-preflight.ts",
    "shadowfax:health": "tsx scripts/shadowfax-runtime.ts health",
    "shadowfax:serviceability": "tsx scripts/shadowfax-runtime.ts serviceability",
    "shadowfax:diagnose": "tsx scripts/shadowfax-runtime.ts diagnose",
    "shadowfax:test-shipment": "tsx scripts/shadowfax-runtime.ts test-shipment"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcrypt": "^5.1.1",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/bcrypt": "^5.0.2",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@hookform/resolvers": "3.9.1"
    }
  }
}
