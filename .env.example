# =============================================================================
# Jebdekho — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Jebdekho
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001
BUYER_SITE_URL=https://jebdekho.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://jebdekho:jebdekho_dev_password@localhost:5432/jebdekho?schema=public

# Docker Compose overrides (used by docker-compose.yml)
POSTGRES_USER=jebdekho
POSTGRES_PASSWORD=jebdekho_dev_password
POSTGRES_DB=jebdekho

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT Authentication (RS256 — asymmetric keys)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KEY_ID=2026-06
# Optional rotation overlap:
# JWT_PRIVATE_KEY_PREVIOUS=
# JWT_PUBLIC_KEY_PREVIOUS=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=jebdekho-api
JWT_AUDIENCE=jebdekho-clients

# -----------------------------------------------------------------------------
# OTP / SMS
# -----------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_REQUESTS=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# Authentication feature flags (email-only until MSG91/DLT approval)
AUTH_EMAIL_ENABLED=true
AUTH_PHONE_OTP_ENABLED=false
AUTH_SMS_ENABLED=false
AUTH_WHATSAPP_ENABLED=false
MSG91_ENABLED=false

# Provider: console (development — prints OTP to logs) | msg91 (production)
SMS_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_SENDER_ID=JEBDKH
MSG91_TEMPLATE_ID=
MSG91_DLT_TE_ID=


# -----------------------------------------------------------------------------
# Email (optional — password reset via email)
# -----------------------------------------------------------------------------
# Email (SMTP — optional in development)
EMAIL_FROM="JebDekho <support@jebdekho.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_FROM=noreply@jebdekho.com
IMAP_HOST=
IMAP_PORT=993

# -----------------------------------------------------------------------------
# Object Storage (MinIO dev / Cloudflare R2 prod)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=jebdekho_minio
S3_SECRET_KEY=jebdekho_minio_secret
S3_BUCKET=jebdekho-uploads
S3_REGION=auto
S3_PUBLIC_URL=http://localhost:9000/jebdekho-uploads

# Cloudflare R2 (production)
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=jebdekho-prod
# S3_PUBLIC_URL=https://cdn.jebdekho.com

# MinIO Docker
MINIO_ROOT_USER=jebdekho_minio
MINIO_ROOT_PASSWORD=jebdekho_minio_secret

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx
# Razorpay Route: automated commission-split settlement to merchant Linked Accounts.
# Keep false until Razorpay activates Route on your account; payouts stay manual meanwhile.
RAZORPAY_ROUTE_ENABLED=false

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
# Server-side key for Geocoding API. Restrict in Google Cloud by server/VPS IP.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Browser key for Maps JavaScript API and Places API. Restrict by HTTP referrer.
# Required APIs: Maps JavaScript API, Places API, Geocoding API.
# Optional when enabled in Google Cloud: Address Validation API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Optional vector map style id for Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAP_ID=

# -----------------------------------------------------------------------------
# Frontend Apps (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Socket.IO origin only — namespaces (/tracking, /analytics, …) are appended by the client.
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# App-specific ports (dev)
BUYER_WEB_PORT=3000
MERCHANT_WEB_PORT=3002
ADMIN_WEB_PORT=3003
RIDER_WEB_PORT=3004
VENDOR_WEB_PORT=3005
FRANCHISE_WEB_PORT=3006

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=10

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Logistics (third-party delivery)
# -----------------------------------------------------------------------------
DELIVERY_PROVIDER=shadowfax
ENABLE_OWN_FLEET=false
ENABLE_SHADOWFAX=true
ENABLE_PORTER=false
ENABLE_DELHIVERY=false
ENABLE_BORZO=false
SHADOWFAX_API_URL=
SHADOWFAX_CLIENT_ID=
SHADOWFAX_CLIENT_SECRET=
SHADOWFAX_TEST_TOKEN=
SHADOWFAX_PRODUCTION_TOKEN=
SHADOWFAX_WEBHOOK_SECRET=
SHADOWFAX_PREALLOCATED_AWBS=
# Example: SHADOWFAX_PREALLOCATED_AWBS=SF10000001JEB-SF10010000JEB
SHADOWFAX_PREALLOCATED_REVERSE_AWBS=

# Borzo (Business API 1.8) — hyperlocal courier. Test host robotapitest-in, prod robot-in.
# Enable via ENABLE_BORZO=true and DELIVERY_PROVIDER=borzo (or keep shadowfax primary).
BORZO_API_URL=https://robotapitest-in.borzodelivery.com/api/business/1.8
BORZO_AUTH_TOKEN=
# HMAC-SHA256 secret for X-DV-Signature on the callback URL /api/v1/webhooks/borzo
BORZO_CALLBACK_TOKEN=
BORZO_VEHICLE_TYPE_ID=8
BORZO_DEFAULT_MATTER=Grocery & retail order
# Example: SHADOWFAX_PREALLOCATED_REVERSE_AWBS=R10000001JEB-R10010000JEB

# -----------------------------------------------------------------------------
# Production Domains (reference)
# -----------------------------------------------------------------------------
# BUYER_URL=https://buyer.jebdekho.com
# MERCHANT_URL=https://merchant.jebdekho.com
# RIDER_URL=https://rider.jebdekho.com
# ADMIN_URL=https://admin.jebdekho.com
# API_URL=https://api.jebdekho.com

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
# Powers phone OTP, order updates, and the admin WhatsApp inbox.
# Never commit real values — set these in .env / .env.production only.
ENABLE_WHATSAPP_OTP=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_OTP_TEMPLATE_NAME=otp
WHATSAPP_OTP_TEMPLATE_LANG=en
# Restricts sends to one number while on a Meta TEST token. Leave blank in production.
WHATSAPP_TEST_RECIPIENT_NUMBER=
# Inbound webhook (https://api.jebdekho.com/api/v1/webhooks/whatsapp)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string; paste the same value into Meta.
# WHATSAPP_APP_SECRET: Meta App Dashboard → App settings → Basic → App secret.
#   When blank, X-Hub-Signature-256 verification is SKIPPED (logs a warning) —
#   set it before going live.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Broadcast pacing: messages/second for CSV bulk sends (Cloud API default cap is 80/s).
WHATSAPP_BROADCAST_RATE_PER_SECOND=10
