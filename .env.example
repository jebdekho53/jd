# =============================================================================
# Jebdekho — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Jebdekho
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001
BUYER_SITE_URL=https://jebdekho.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://jebdekho:jebdekho_dev_password@localhost:5432/jebdekho?schema=public

# Docker Compose overrides (used by docker-compose.yml)
POSTGRES_USER=jebdekho
POSTGRES_PASSWORD=jebdekho_dev_password
POSTGRES_DB=jebdekho

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT Authentication (RS256 — asymmetric keys)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KEY_ID=2026-06
# Optional rotation overlap:
# JWT_PRIVATE_KEY_PREVIOUS=
# JWT_PUBLIC_KEY_PREVIOUS=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=jebdekho-api
JWT_AUDIENCE=jebdekho-clients

# -----------------------------------------------------------------------------
# OTP / SMS
# -----------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_REQUESTS=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# Provider: console (development — prints OTP to logs) | msg91 (production)
SMS_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_SENDER_ID=JEBDKH
MSG91_TEMPLATE_ID=
MSG91_DLT_TE_ID=

# Demo login (development only)
DEV_DEMO_PHONE=+919876543210
DEV_DEMO_MERCHANT_PHONE=+919876543211
DEV_DEMO_MERCHANT_EMAIL=merchant@demo.jebdekho.com
DEV_DEMO_MERCHANT_PHONE_2=+919876543213
DEV_DEMO_MERCHANT_EMAIL_2=merchant2@demo.jebdekho.com
DEV_DEMO_ADMIN_PHONE=+919876543212
DEV_DEMO_ADMIN_EMAIL=admin@demo.jebdekho.com
DEV_DEMO_RIDER_PHONE=+919876543214
DEV_DEMO_OTP=123456

# -----------------------------------------------------------------------------
# Email (optional — password reset via email)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@jebdekho.com

# -----------------------------------------------------------------------------
# Object Storage (MinIO dev / Cloudflare R2 prod)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=jebdekho_minio
S3_SECRET_KEY=jebdekho_minio_secret
S3_BUCKET=jebdekho-uploads
S3_REGION=auto
S3_PUBLIC_URL=http://localhost:9000/jebdekho-uploads

# Cloudflare R2 (production)
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=jebdekho-prod
# S3_PUBLIC_URL=https://cdn.jebdekho.com

# MinIO Docker
MINIO_ROOT_USER=jebdekho_minio
MINIO_ROOT_PASSWORD=jebdekho_minio_secret

# -----------------------------------------------------------------------------
# Razorpay
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# -----------------------------------------------------------------------------
# Frontend Apps (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# App-specific ports (dev)
BUYER_WEB_PORT=3000
MERCHANT_WEB_PORT=3002
ADMIN_WEB_PORT=3003
RIDER_WEB_PORT=3004
VENDOR_WEB_PORT=3005
FRANCHISE_WEB_PORT=3006

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=10

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Production Domains (reference)
# -----------------------------------------------------------------------------
# BUYER_URL=https://buyer.jebdekho.com
# MERCHANT_URL=https://merchant.jebdekho.com
# RIDER_URL=https://rider.jebdekho.com
# ADMIN_URL=https://admin.jebdekho.com
# API_URL=https://api.jebdekho.com
