# =============================================================================
# JebDekho — PRODUCTION Environment Template
# Copy to /var/www/jebdekho/.env.production on the VPS and fill secrets.
# NEVER commit filled .env.production to version control.
# =============================================================================

NODE_ENV=production
APP_NAME=Jebdekho
APP_URL=https://jebdekho.com
API_URL=https://api.jebdekho.com
API_PORT=3001
BUYER_SITE_URL=https://jebdekho.com

# -----------------------------------------------------------------------------
# Domains (reference)
# -----------------------------------------------------------------------------
BUYER_URL=https://jebdekho.com
ADMIN_URL=https://admin.jebdekho.com
MERCHANT_URL=https://merchant.jebdekho.com
RIDER_URL=https://rider.jebdekho.com
VENDOR_URL=https://vendor.jebdekho.com
FRANCHISE_URL=https://franchise.jebdekho.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL on VPS or managed)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://jebdekho:CHANGE_ME@127.0.0.1:5432/jebdekho_prod?schema=public&sslmode=prefer
POSTGRES_USER=jebdekho
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=jebdekho_prod

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# JWT (RS256 — generate fresh keys for production)
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_KEY_ID=prod-2026
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=https://api.jebdekho.com
JWT_AUDIENCE=jebdekho-clients

# -----------------------------------------------------------------------------
# OTP / SMS (production)
# -----------------------------------------------------------------------------
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=JEBDKH
MSG91_TEMPLATE_ID=
MSG91_DLT_TE_ID=

# Disable demo login in production
DEV_DEMO_PHONE=
DEV_DEMO_OTP=

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM=noreply@jebdekho.com

# -----------------------------------------------------------------------------
# Storage — local uploads on VPS (or switch to R2)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
UPLOAD_DIR=/var/www/jebdekho/uploads
UPLOAD_PUBLIC_URL=https://api.jebdekho.com/uploads
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=jebdekho-prod
# S3_REGION=auto
# S3_PUBLIC_URL=https://cdn.jebdekho.com

# -----------------------------------------------------------------------------
# Razorpay (LIVE keys)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=https://jebdekho.com/checkout

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Frontend (build-time for Next.js apps)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.jebdekho.com/api/v1
NEXT_PUBLIC_API_ORIGIN=https://api.jebdekho.com
NEXT_PUBLIC_WS_URL=wss://api.jebdekho.com
NEXT_PUBLIC_SITE_URL=https://jebdekho.com

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://jebdekho.com,https://www.jebdekho.com,https://admin.jebdekho.com,https://merchant.jebdekho.com,https://rider.jebdekho.com,https://vendor.jebdekho.com,https://franchise.jebdekho.com

# -----------------------------------------------------------------------------
# Security / Ops
# -----------------------------------------------------------------------------
TRUST_PROXY=true
LOG_LEVEL=info
THROTTLE_TTL=60000
THROTTLE_LIMIT=200
AUTH_THROTTLE_LIMIT=20

# SENTRY_DSN=
